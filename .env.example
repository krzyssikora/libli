# Copy to .env for local development. config/settings/base.py reads this file
# when it exists; in CI and production the same variables come from the real
# environment instead. See docs/development/setup.md.

# --- core (all environments) ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me                       # generate a random value; never commit a real one
DJANGO_DEBUG=true                                 # true locally; MUST be false in production
DATABASE_URL=postgres://libli:libli@localhost:5432/libli
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1          # comma-separated hostnames

# --- local dev extras (have safe defaults; override only if needed) ---
# Whitelisted hosts for video/iframe embeds (comma-separated bare hostnames).
# LIBLI_ALLOWED_EMBED_DOMAINS=www.youtube.com,youtube.com,youtu.be,player.vimeo.com,www.geogebra.org,geogebra.org
# Absolute origin (scheme+host, no trailing slash) baked into the HTML-element sandbox CSP.
# DJANGO_HTMLEL_SANDBOX_ORIGIN=http://localhost:8000

# --- production only (config.settings.production) ---
# Redirect all HTTP to HTTPS (default true; set false only if TLS is terminated elsewhere
# and you handle the redirect there).
# DJANGO_SECURE_SSL_REDIRECT=true
# Set true when running behind a TLS-terminating reverse proxy (trusts X-Forwarded-Proto).
# DJANGO_BEHIND_PROXY=true
# CSRF trusted origins, comma-separated scheme+host entries (required behind HTTPS).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://libli.example.org,https://www.libli.example.org
#
# Email: set DJANGO_EMAIL_HOST to enable SMTP. Left unset, mail is logged to the
# console (visibly unconfigured) instead of silently failing to localhost.
# DJANGO_EMAIL_HOST=smtp.example.org
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=                      # secret — supply via the environment, not a committed file
# DJANGO_EMAIL_USE_TLS=true
# DJANGO_DEFAULT_FROM_EMAIL=libli <no-reply@example.org>

# --- bootstrap (read by `manage.py init_platform`; or entered interactively) ---
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_EMAIL=admin@example.org
# INIT_ADMIN_PASSWORD=                             # secret — set in the environment when scripting the bootstrap
