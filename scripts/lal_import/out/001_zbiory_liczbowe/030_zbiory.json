          "figcaption": ""
        }
      ]
    },
    {
      "type": "spoiler",
      "label": "\\(A'\\)",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n<strong>\n                                dopełnienie zbioru\n                            </strong>\n</p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            wszystkie elementy z całej przestrzeni \\(U\\), które nie należą do zbioru \\(A\\)\n                        </p>"
