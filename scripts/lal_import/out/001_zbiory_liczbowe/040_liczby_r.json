        {
          "type": "text",
          "body": "<p>\n                            Liczby, których w naturalny sposób używamy do liczenia obiektów, które obserwujemy, np.\n                        </p>"
        },
        {
          "type": "text",
          "body": "<ul>\n<li>\n                                \\(0\\) drzew\n                            </li>\n<li>\n                                \\(1\\) drzewo\n                            </li>\n<li>\n                                \\(2\\) drzewa\n                            </li>\n<li>\n                                \\(3\\) drzewa\n                            </li>\n<li>\n                                itd\n                            </li>\n</ul>"
