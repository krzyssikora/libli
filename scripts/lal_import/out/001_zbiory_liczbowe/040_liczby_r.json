      "elements": [
        {
          "type": "text",
          "body": "<p class=\"important\">\n                            symbol: \\(\\mathbb{Q}\\)\n                        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            Liczby, które możemy przedstawić w postaci ułamka (nieskracalnego):\n                        </p>"
        },
        {
          "type": "math",
          "latex": "\\frac{p}{q}"
        },
        {
          "type": "text",
          "body": "<p>\n                            gdzie zarówno licznik (\\(p\\)) jak i mianownik (\\(q\\)) to liczby całkowite.\n                        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            Przykładowe liczby wymierne to:\n                        </p>"
        },
        {
          "type": "text",
          "body": "\n                            \\[\\frac{1}{2},\\quad\\quad-2\\frac{1}{3}=\\frac{-7}{3},\\quad\\quad 4,01=\\frac{401}{100},\\quad\\quad 4,(5)=4\\frac{5}{9}=\\frac{41}{9}\\]\n                        "
        },
        {
          "type": "text",
          "body": "<p>\n                            Liczbami wymiernymi nie są:\n                        </p>"
        },
        {
          "type": "text",
          "body": "\n                            \\[\\sqrt{2},\\quad\\quad \\sqrt[3]{5},\\quad\\quad 3+\\sqrt{7},\\quad\\quad \\pi\\]\n                        "
        },
        {
          "type": "text",
          "body": "<p>\n                            i setki, tysiące innych.\n                        </p>"
