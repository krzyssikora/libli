{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n    Większość obliczeń procentowych sprowadza się do trzech podstawowych obliczeń procentowych. Kliknij na opis, aby zobaczyć dwie metody obliczenia (\"zwykłą\" i proporcjami).\n</p>"
    },
    {
      "type": "text",
      "body": "<h4>obliczenia procentu z liczby</h4>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n            Oblicz \\(15\\%\\) z liczby \\(240\\).\n        "
    },
    {
      "type": "tabs",
      "tabs": [
        {
          "id": "t000000",
          "label": "\"normalnie\"",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                \\(1\\%\\) to \\(\\frac{1}{100}\\), czyli \\(15\\%\\) z liczby \\(240\\) to\n            </p>"
            },
            {
              "type": "math",
              "latex": "15\\%\\cdot 240=\\frac{15}{100}\\cdot 240=\\frac{3}{20}\\cdot 240=3\\cdot 12=36"
            }
          ]
        },
        {
          "id": "t000001",
          "label": "proporcje",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                Proporcje w tym i kolejnych przykładach ułożymy według schematu:\n            </p>"
            },
            {
              "type": "math",
              "latex": "\n            \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n            \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}\n            "
            },
            {
              "type": "text",
              "body": "<ol>\n<li>\n                    Całość wyrażona w procentach to zawsze \\(100\\%\\):\n                    \\[\n                    \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n                    \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\\\square\\end{matrix}}{100\\%}\n                    \\]\n                </li>\n<li>\n                    Ta całość jako liczba to \\(240\\):\n                    \\[\n                    \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n                    \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{240}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\\\square\\end{matrix}}{100\\%}\n                    \\]\n                </li>\n<li>\n                    Szukamy \\(15\\%\\) z tej liczby:\n                    \\[\n                    \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n                    \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{240}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\15\\%\\end{matrix}}{100\\%}\n                    \\]\n                </li>\n<li>\n                    Oznaczmy szukaną przez \\(x\\):\n                    \\[\n                    \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n                    \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\x\\end{matrix}}{240}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\15\\%\\end{matrix}}{100\\%}\n                    \\]\n                </li>\n</ol>"
            },
            {
              "type": "text",
              "body": "<p>\n                Otrzymaliśmy proporcję:\n            </p>"
            },
            {
              "type": "math",
              "latex": "\\frac{x}{240}=\\frac{15\\%}{100\\%}"
            },
            {
              "type": "text",
              "body": "<p>\n                Skróćmy procenty po prawej stronie, a następnie pomnóżmy na krzyż:\n            </p>"
            },
            {
              "type": "math",
              "latex": "100x=15\\cdot 240"
            },
            {
              "type": "text",
              "body": "<p>\n                otrzymujemy:\n            </p>"
            },
            {
              "type": "math",
              "latex": "100x=3600"
            },
            {
              "type": "text",
              "body": "<p>\n                czyli:\n            </p>"
            },
            {
              "type": "math",
              "latex": "x=36"
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "body": "<h4>obliczenia, jakim procentem jednej liczby jest inna liczba</h4>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n            Oblicz jakim procentem liczby \\(240\\) jest liczba \\(180\\).\n        "
    },
    {
      "type": "tabs",
      "tabs": [
        {
          "id": "t000000",
          "label": "\"normalnie\"",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                Podzielmy część przez całość i zamieńmy na procenty:\n            </p>"
            },
            {
              "type": "math",
              "latex": "\\frac{180}{240}\\cdot 100\\%=\\frac{3}{4}\\cdot 100\\%=75\\%"
            }
          ]
        },
        {
          "id": "t000001",
          "label": "proporcje",
          "elements": [
            {
              "type": "math",
              "latex": "\n            \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n            \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}\n            "
            },
            {
              "type": "text",
              "body": "<p>\n                Całość w procentach to \\(100\\%\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Całość jako liczba to \\(240\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Część, którą mamy zamienić na procenty to \\(180\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Szukany procent to \\(x\\).\n            </p>"
            },
            {
              "type": "math",
              "latex": "\\frac{180}{240}=\\frac{x}{100\\%}"
            },
            {
              "type": "text",
              "body": "<p>\n                Skracamy ułamki, mnożymy na krzyż:\n            </p>"
            },
            {
              "type": "math",
              "latex": "\n            \\begin{align}\n            \\frac{3}{4}&=\\frac{x}{100\\%}\\\\[10pt]\n            4x&=300\\%\\\\[10pt]\n            x&=\\frac{300\\%}{4}=75\\%\n            \\end{align}\n            "
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "body": "<h4>obliczenia liczby, której procent jest dany</h4>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n            Znajdź liczbę, której \\(12\\%\\) to \\(18\\).\n        "
    },
    {
      "type": "tabs",
      "tabs": [
        {
          "id": "t000000",
          "label": "\"normalnie\"",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                \\(18\\) jest wynikiem mnożenia szukanej liczby przez \\(12\\%\\), więc by znaleźć tę liczbę należy podzielić \\(18\\) przez \\(12\\%\\):\n            </p>"
            },
            {
              "type": "math",
              "latex": "\\frac{18}{12\\%}=\\frac{18}{0,12}=\\frac{1800}{12}=150"
            }
          ]
        },
        {
          "id": "t000001",
          "label": "proporcje",
          "elements": [
            {
              "type": "math",
              "latex": "\n            \\begin{matrix}\\text{część}\\rightarrow\\\\\\text{całość}\\rightarrow\\end{matrix}\n            \\frac{\\begin{matrix}\\text{liczba}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}=\\frac{\\begin{matrix}\\text{procent}\\\\\\downarrow\\\\\\square\\end{matrix}}{\\square}\n            "
            },
            {
              "type": "text",
              "body": "<p>\n                Całość w procentach to \\(100\\%\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Całość jako liczba to nasza niewiadoma, \\(x\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Część w procentach to \\(12\\%\\).\n            </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                Ta sama część jako liczba to \\(18\\).\n            </p>"
            },
            {
              "type": "math",
              "latex": "\\frac{18}{x}=\\frac{12\\%}{100\\%}"
            },
            {
              "type": "text",
              "body": "<p>\n                Skracamy ułamki, mnożymy na krzyż:\n            </p>"
            },
            {
              "type": "math",
              "latex": "\n            \\begin{align}\n            \\frac{18}{x}&=\\frac{3}{25}\\\\[10pt]\n            3x&=18\\cdot 25\\%\\\\[10pt]\n            x&=6\\cdot 25=150\\%\n            \\end{align}\n            "
            }
          ]
        }
      ]
    }
  ],
  "fully_mapped": true,
  "seed_hash": "0c23ada923a0fe29d7434f5a2bacffd2a94d2e2e360cebef3f88f244c5dcf39a"
}