    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            W trapezie \\(ABCD\\), w którym \\(AB\\parallel CD\\) punkty \\(M\\) i \\(N\\) to środki ramion \\(AD\\) i \\(BC\\) odpowiednio.\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Ramię \\(AD\\) jest prostopadłe do podstaw.\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Wiedząc, że długości odcinków \\(AB\\), \\(AM\\) i \\(MN\\) to odpowiednio \\(11\\), \\(4\\) i \\(8\\), oblicz obwód trapezu \\(ABCD\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n<small>Uwaga! Zanim przejdziesz do rozwiązania, wykonaj samodzielnie rysunek pomocniczy.</small>\n</p>"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                    Przyjrzyj się poniższemu rysunkowi, przeczytaj ponownie treść zadania i sprawdź, czy wszystko się zgadza.\n                </p>"
        },
        {
          "type": "image",
          "media_src": "static/geometria_3_zadanie_260_1.png",
          "alt": "",
          "figcaption": ""
        },
        {
          "type": "text",
          "body": "<p>\n                    Znamy długości zaznaczone na niebiesko, musimy poznać te zaznaczone na szaro.\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Zacznijmy od \\(DM\\). Ta jest najprostsza, bo\n                    \n\n\n\n￿0￿.\n                ",
