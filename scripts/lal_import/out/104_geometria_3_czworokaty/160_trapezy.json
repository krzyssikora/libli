        },
        {
          "type": "text",
          "body": "<p>\n                    Oznaczmy długość dolnej podstawy przez \\(a\\).\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Wówczas\n                    \n\n\n\n￿0￿.\n                ",
