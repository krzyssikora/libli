            "jest równa długości \\(CD\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Czyli długość \\(DM\\) to \\(4\\).\n                </p>"
        },
        {
          "type": "image",
          "media_src": "static/geometria_3_zadanie_260_2.png",
          "alt": "",
          "figcaption": ""
        },
        {
