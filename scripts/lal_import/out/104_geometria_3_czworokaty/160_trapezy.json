          "alt": "",
          "figcaption": ""
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Pozostało nam ustalić długości odcinków \\(BN\\) i \\(CN\\), które są\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
