          "answer": 1
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Rozwiązując równanie \\(7=\\frac{a+5}{2}\\) otrzymujemy\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a=9\\)",
