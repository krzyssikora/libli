    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Czworokąt \\(A_2B_2C_2D_2\\) jest podobny do czworokąta \\(A_1B_1C_1D_1\\). Kąty wewenętrzne pierwszego wielokąta w wierzchołkach \\(A_1\\), \\(B_1\\), \\(C_1\\) i \\(D_1\\) są równe kątom wewnętrznym drugiego wielokąta w wierzchołkach \\(A_2\\), \\(B_2\\), \\(C_2\\) i \\(D_2\\) odpowiednio.\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Obwód czworokąta \\(A_1B_1C_1D_1\\) jest równy \\(28\\) centymetrów, a obwód czworokąta \\(A_2B_2C_2D_2\\) jest równy \\(42\\) centymetrów.\n        </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\">\n<li>\n                Jaka jest skala podobieństwa czworokąta \\(A_2B_2C_2D_2\\) do czworokąta \\(A_1B_1C_1D_1\\)?\n            </li>\n</ol>"
    },
    {
      "type": "text",
      "body": "<p>\n            Odcinek \\(B_1C_1\\) jest długości \\(8\\) centymetrów.\n        </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\" start=\"2\">\n<li>\n                Jaka jest długość odcinka \\(B_2C_2\\)?\n            </li>\n</ol>"
    },
    {
      "type": "text",
      "body": "<p>\n            Odcinek \\(A_2D_2\\) jest długości \\(9\\) centymetrów.\n        </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\" start=\"3\">\n<li>\n                Jaka jest długość odcinka \\(A_1D_1\\)?\n            </li>\n</ol>"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                    Oznaczmy dla ułatwienia\n                </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                        wielokąt \\(A_1B_1C_1D_1\\) przez \\(W_1\\),\n                    </li>\n<li>\n                        wielokąt \\(A_2B_2C_2D_2\\) przez \\(W_2\\).\n                    </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n                    Odpowiemy na trzy pytania po kolei.\n                </p>"
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\">\n<li>\n                        Jaka jest skala podobieństwa czworokąta \\(A_2B_2C_2D_2\\) do czworokąta \\(A_1B_1C_1D_1\\)?\n                    </li>\n</ol>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Tę skalę podobieństwa, \\(k\\), obliczymy z wyrażenia \n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{28}{42}\\)",
            "\\(\\frac{42}{28}\\)",
            "\\(\\frac{42-28}{28}\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Zgadza się, \n                </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                        aby znaleźć skalę podobieństwa wielokąta \\(W_2\\) do wielokąta \\(W_1\\), \n                    </li>\n<li>\n                        dzielimy długość z wielokąta \\(W_2\\) przez odpowiednią długość z wielokąta \\(W_1\\), \n                    </li>\n<li>\n                        na przykład obwód \\(W_2\\) przez obwód \\(W_1\\).\n                    </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n                    Tak więc skala podobieństwa:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                k=\\frac{42}{28}=\\frac{3}{2}\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    Teraz wiedząc, że odcinek \\(B_1C_1\\) jest długości \\(8\\) centymetrów, odpowiemy na pytanie:\n                </p>"
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\" start=\"2\">\n<li>\n                        Jaka jest długość odcinka \\(B_2C_2\\)?\n                    </li>\n</ol>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Obliczymy ją z równania\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(B_2C_2=\\frac{3}{2}\\cdot B_1C_1\\)",
