            "\\(90^{\\circ}\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Kąty wewnętrzne w obu trójkątach mają miary \\(45^{\\circ}\\), \\(45^{\\circ}\\) i \\(90^{\\circ}\\).\n                </p>"
        },
        {
          "type": "image",
