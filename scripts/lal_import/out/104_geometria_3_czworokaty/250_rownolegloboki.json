      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            W równoległoboku \\(ABCD\\) wysokość \\(DE\\) opada na bok \\(AB\\) i dzieli go na odcinki \\(AE=2\\sqrt{2}\\) i \\(BE=5\\sqrt{2}\\). \n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Długość boku \\(BC\\) to \\(2\\sqrt{3}\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Oblicz pole równoległoboku.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                    Zacznijmy od rysunku:\n                </p>"
