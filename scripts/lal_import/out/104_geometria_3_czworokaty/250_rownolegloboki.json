          "figcaption": ""
        },
        {
          "type": "text",
          "body": "<p>\n                    Wysokość \\(h\\) możemy obliczyć z twierdzenia Pitagorasa. \n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Równanie \\(h^2+(2\\sqrt{2})^2=(2\\sqrt{3})^2\\) możemy przekształcić do postaci\n                    \n\n\n\n￿0￿.\n                ",
