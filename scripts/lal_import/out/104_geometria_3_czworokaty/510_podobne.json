                  "halign": "left",
                  "valign": "top"
                },
                {
                  "html": "\\(\\tfrac{1}{2}a\\)",
                  "halign": "left",
                  "valign": "top"
                },
                {
                  "html": "\\(\\frac{b}{\\tfrac{1}{2}a}\\)",
                  "halign": "left",
                  "valign": "top"
                }
              ]
            ]
          }
        },
        {
          "type": "text",
          "body": "<p>\n                    Stosunki długości boków obu prostokątów muszą być równe, czyli:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                \\frac{a}{b}=\\frac{b}{\\tfrac{1}{2}a}\n                "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Mnożąc równanie na skos, a następnie obie strony przez \\(2\\) otrzymujemy\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a^2=2b^2\\)",
            "\\(2a^2=b^2\\)",
            "\\(a^2=b^4\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>Z równania \\(a^2=2b^2\\) wynika, że\n                \\[\n                \\frac{a^2}{b^2}=2\n                \\]</p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    a stąd (pierwiastkując) otrzymujemy\n                    \n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{a}{b}=\\sqrt{2}\\)",
            "\\(\\frac{a}{b}=2\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Stosunek długości dłuższego do krótszego boku kartki papieru jest równy \\(\\sqrt{2}\\).\n                </p>"
        },
        {
          "type": "text",
          "body": "<p><strong>Przykład</strong></p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            \\(\\sqrt{2}\\) to w przybliżeniu \\(1,414213562\\).\n                        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            Wymiary kartki A4 to \\(297\\) na \\(210\\) milimetrów. Stosunek tych długości to w przybliżeniu \\(1,414285714\\).\n                        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                            Błąd względny to zaledwie \\(0,0051\\%\\)!\n                        </p>"
        }
      ]
    }
