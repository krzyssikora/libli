                  "alt": "",
                  "figcaption": ""
                },
                {
                  "type": "text",
                  "body": "<p>Na rysunku długości odcinków na przekątnych są oznaczone:</p>"
                },
                {
                  "type": "text",
                  "body": "<ul>\n<li>\n                                    \\(AE=c\\), \\(CE=c\\), dzięki czemu \\(AE:CE=1\\),\n                                </li>\n<li>\n                                    \\(BE=5d\\), \\(DE=9d\\), dzięki czemu \\(BE:DE=5:9\\).\n                                </li>\n</ul>"
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Zauważmy, że trójkąty \\(AED\\) oraz \\(CED\\) są\n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "podobne",
                    "przystające",
                    "równoramienne"
                  ],
                  "answer": 1
                },
                {
                  "type": "text",
                  "body": "<p>Trójkąty \\(AED\\) oraz \\(CED\\) są przystające na mocy zasady</p>"
