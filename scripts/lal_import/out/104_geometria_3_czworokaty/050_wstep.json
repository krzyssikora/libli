                    "\\(BE=36\\) oraz \\(DE=20\\)",
                    "\\(BE=20\\) oraz \\(DE=36\\)",
                    "\\(BE=28\\) oraz \\(DE=28\\)"
                  ],
                  "answer": 1
                },
                {
                  "type": "text",
                  "body": "<p>Nanieśmy wyliczone wielokości na rysunek:</p>"
                },
                {
                  "type": "image",
                  "media_src": "static/geometria_3_zadanie_80_2.png",
                  "alt": "",
                  "figcaption": ""
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Z twierdzenia Pitagorasa obliczmy długość \\(AB\\) (równą długości \\(BC\\)):\n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "\\(AB^2=15^2+20^2\\)",
                    "\\(15^2=AB^2+20^2\\)",
                    "\\(20^2=AB^2+15^2\\)"
                  ],
                  "answer": 0
                },
                {
                  "type": "text",
                  "body": "\n                                \\[\n                                \\begin{align}\n                                AB^2&amp;=AE^2+BE^2\\\\\n                                AB^2&amp;=15^2+20^2\\\\\n                                AB^2&amp;=225+400\\\\\n                                AB^2&amp;=625\n                                \\end{align}\n                                \\]\n                            "
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Długości \\(AB\\) i \\(BC\\) są równe, więc\n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "\\(AB=BC=15\\)",
                    "\\(AB=BC=25\\)",
                    "\\(AB=BC=35\\)"
                  ],
                  "answer": 1
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Podobnie z twierdzenia Pitagorasa obliczmy długość \\(AD\\) (równą długości \\(CD\\)):\n                                \n\n\n￿0￿.\n                            ",
                  "options": [
                    "\\(36^2=AD^2+15^2\\)",
                    "\\(AD^2=15^2+36^2\\)"
                  ],
                  "answer": 1
                },
                {
                  "type": "text",
                  "body": "\n                                \\[\n                                \\begin{align}\n                                AD^2&amp;=AE^2+DE^2\\\\\n                                AD^2&amp;=15^2+36^2\\\\\n                                AD^2&amp;=225+1296\\\\\n                                AD^2&amp;=1529\n                                \\end{align}\n                                \\]\n                            "
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Długości \\(AD\\) i \\(CD\\) są równe, więc\n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "\\(AD=CD=39\\)",
                    "\\(AD=CD=41\\)",
                    "\\(AD=CD=49\\)"
                  ],
                  "answer": 0
                },
                {
                  "type": "text",
                  "body": "<p>Dopiszmy znalezione długości boków do rysunku:</p>"
                },
                {
                  "type": "image",
                  "media_src": "static/geometria_3_zadanie_80_3.png",
                  "alt": "",
                  "figcaption": ""
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Obwód czworokąta to suma długości wszystkich boków, czyli\n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "\\(128\\)",
                    "\\(64\\)",
                    "\\(214\\)"
                  ],
                  "answer": 0
                },
                {
                  "type": "text",
                  "body": "<p>Obwód czworokąta jest równy</p>"
                },
                {
                  "type": "text",
                  "body": "\n                                \\[\n                                AB+BC+CD+AD=25+25+39+39=128\n                                \\]\n                            "
                }
              ]
            },
            {
              "type": "spoiler",
              "label": "3.wyliczenie pola czworokąta",
              "elements": [
                {
                  "type": "text",
                  "body": "<p>\n                                Pole całego czworokąta jest sumą pól czterech trójkątów prostokątnych. Zacznijmy od zaznaczonego niżej na szaro.\n                            </p>"
