                {
                  "type": "text",
                  "body": "<ul>\n<li>\n                                    mają wspólny bok \\(DE\\),\n                                </li>\n<li>\n                                    boki \\(AE\\) i \\(CE\\) są równej długości,\n                                </li>\n<li>\n                                    kąty między tymi bokami są równej miary (bo są proste).\n                                </li>\n</ul>"
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Z tego wynika, że \n                                \n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "odcinki \\(AD\\) oraz \\(CD\\) są równej długości",
