            {
              "type": "spoiler",
              "label": "2.wyliczenie obwodu czworokąta",
              "elements": [
                {
                  "type": "text",
                  "body": "<p>Zacznijmy od obliczenia długości odcinków, na jakie punkt \\(E\\) dzieli przekątne czworokąta. Ponownie przyjrzyj się rysunkowi:</p>"
                },
                {
                  "type": "image",
