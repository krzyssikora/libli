                  "alt": "",
                  "figcaption": ""
                },
                {
                  "type": "switch_gate",
                  "stem": "\n                                Przekątna \\(AC\\) jest długości \\(30\\), więc długości \\(AE\\) i \\(CE\\)\n                                \n\n\n\n\n￿0￿.\n                            ",
                  "options": [
                    "są obie równe \\(30\\)",
