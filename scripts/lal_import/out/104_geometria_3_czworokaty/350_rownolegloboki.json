    {
      "type": "text",
      "body": "\n<p>\n            Pole prostokąta o przekątnej długości \\(d\\) i kącie między przekątnymi o mierze \\(\\alpha\\) jest równe \\(P\\).\n        </p>\n<div class=\"switch_steps\">\n<div class=\"switch_step\">\n<div class=\"switch_line\">\n<strong>1.</strong> Jeśli \\(d=6\\) i \\(\\alpha=30^{\\circ}\\), to \\(P=\\)\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(36\\)</div>\n<div class=\"switch_value\">\\(18\\)</div>\n<div class=\"switch_value\">\\(9\\)</div>\n<div class=\"switch_value\">\\(9\\sqrt{3}\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n<strong>2.</strong> Jeśli \\(d=7\\) i \\(\\alpha=45^{\\circ}\\), to \\(P=\\)\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(49\\)</div>\n<div class=\"switch_value\">\\(49\\sqrt{2}\\)</div>\n<div class=\"switch_value\">\\(\\tfrac{49}{2}\\)</div>\n<div class=\"switch_value\">\\(\\tfrac{49\\sqrt{2}}{4}\\)</div>\n<div class=\"switch_value\">\\(\\tfrac{49}{4}\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n<strong>3.</strong> Jeśli \\(d=8\\) i \\(P=16\\), to \\(\\alpha=\\)\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(30^{\\circ}\\)</div>\n<div class=\"switch_value\">\\(45^{\\circ}\\)</div>\n<div class=\"switch_value\">\\(60^{\\circ}\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n<strong>4.</strong> Jeśli \\(d=6\\) i \\(P=9\\sqrt{3}\\), to \\(\\alpha=\\)\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(30^{\\circ}\\)</div>\n<div class=\"switch_value\">\\(45^{\\circ}\\)</div>\n<div class=\"switch_value\">\\(60^{\\circ}\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n<strong>5.</strong> Jeśli \\(P=6\\sqrt{2}\\) i \\(\\alpha=45^{\\circ}\\), to \\(d=\\)\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(2\\sqrt{6}\\)</div>\n<div class=\"switch_value\">\\(2\\sqrt{3}\\)</div>\n<div class=\"switch_value\">\\(3\\sqrt{2}\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n                Świetnie!\n            </div>\n</div>\n"
    }
