{3}}{2}\\)\n                            </td>\n<td>\n                                \\(\\frac{\\sqrt{3}}{2}\\)\n                            </td>\n<td>\n                                \\(\\frac{\\sqrt{2}}{2}\\)\n                            </td>\n<td>\n                                \\(\\frac{1}{2}\\)\n                            </td>\n</tr>\n</table>",
