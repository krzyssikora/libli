      "figcaption": ""
    },
    {
      "type": "switch_gate",
      "stem": "\n                Dla punktu \\((x,y)\\) w trzeciej ćwiartce\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(x\\gt 0\\) i \\(y\\gt 0\\)",
        "\\(x\\gt 0\\) i \\(y\\lt 0\\)",
        "\\(x\\lt 0\\) i \\(y\\gt 0\\)",
        "\\(x\\lt 0\\) i \\(y\\lt 0\\)"
      ],
      "answer": 3
    },
    {
      "type": "switch_gate",
      "stem": "\n                Dla punktu \\((x,y)\\) w czwartej ćwiartce\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(x\\gt 0\\) i \\(y\\gt 0\\)",
        "\\(x\\gt 0\\) i \\(y\\lt 0\\)",
        "\\(x\\lt 0\\) i \\(y\\gt 0\\)",
        "\\(x\\lt 0\\) i \\(y\\lt 0\\)"
