{
  "elements": [
    {
      "type": "text",
      "body": "<ul class=\"nolist\">\n<li style=\"margin-bottom: 20px;\">\n            \\(\\sin^2\\alpha+\\cos^2\\alpha=1\\) (tzw.\n            <strong>\n                jedynka trygonometryczna\n            </strong>\n            )\n        </li>\n<li style=\"margin-bottom: 20px;\">\n            \\(\\text{tg }\\alpha = \\frac{\\sin\\alpha}{\\cos\\alpha}\\) oraz \\(\\text{ctg }\\alpha = \\frac{\\cos\\alpha}{\\sin\\alpha}\\)\n        </li>\n<li>\n            \\(\\text{tg }\\alpha\\cdot\\text{ctg }\\alpha = 1\\)\n        </li>\n</ul>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Dany jest kąt \\(\\alpha\\), gdzie \\(180^{\\circ}\\lt\\alpha\\lt 270^{\\circ}\\) oraz\n        </p>"
    },
    {
      "type": "math",
      "latex": "\n        \\frac{6\\sin\\alpha-\\cos\\alpha}{2\\cos\\alpha-\\sin\\alpha}=2\n        "
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\">\n<li>\n                Znajdź dokładną wartość \\(\\text{tg }\\alpha\\).\n            </li>\n<li>\n                Użyj tablic trygonometrycznych, aby oszacować wartość kąta \\(alpha\\) z dokładnością do \\(1^{\\circ}\\).\n            </li>\n</ol>"
    },
    {
      "type": "text",
      "body": "<p>\n                Mamy znaleźć \\(\\text{tg }\\alpha\\), którego nie ma w danym równaniu. Najlepiej będzie zacząć od uproszczenia równania.\n            </p>"
    },
    {
      "type": "switch_gate",
      "stem": "\n                Przemnóżmy obie strony równania przez mianownik z lewej strony. Otrzymamy:\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(6\\sin\\alpha-\\cos\\alpha=2\\cos\\alpha-\\sin\\alpha\\)",
        "\\(6\\sin\\alpha-\\cos\\alpha=4\\cos\\alpha-\\sin\\alpha\\)",
        "\\(6\\sin\\alpha-\\cos\\alpha=4\\cos\\alpha-2\\sin\\alpha\\)",
        "\\(12\\sin\\alpha-2\\cos\\alpha=2\\cos\\alpha-\\sin\\alpha\\)"
      ],
      "answer": 2
    },
    {
      "type": "switch_gate",
      "stem": "\n                Przenieśmy \\(\\sin\\alpha\\) na lewo, a \\(\\cos\\alpha\\) na prawo, by otrzymać\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(8\\sin\\alpha=5\\cos\\alpha\\)",
        "\\(2\\sin\\alpha=-\\cos\\alpha\\)",
        "\\(2\\cos\\alpha=-\\sin\\alpha\\)",
        "\\(4\\sin\\alpha=5\\cos\\alpha\\)"
      ],
      "answer": 0
    },
    {
      "type": "text",
      "body": "<p>\n                Pamiętamy, że\n            </p>"
    },
    {
      "type": "math",
      "latex": "\n                                                                                                \\text{tg }\\alpha =\\frac{\\sin\\alpha}{\\cos\\alpha}\n                                                                                                "
    },
    {
      "type": "switch_gate",
      "stem": "\n                Podzielmy więc obie strony równania przez \\(\\cos\\alpha\\)\n                \n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(8\\text{tg }\\alpha=5\\)",
        "\\(5\\text{tg }\\alpha=8\\)"
      ],
      "answer": 0
    },
    {
      "type": "switch_gate",
      "stem": "\n                I dlatego \\(\\text{tg }\\alpha=\\)\n                \n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(\\tfrac{8}{5}\\)",
        "\\(0,625\\)",
        "\\(-3\\)"
      ],
      "answer": 1
    },
    {
      "type": "text",
      "body": "<p>\n                Odpowiedzieliśmy na pytanie pierwsze. Wartość \\(\\text{tg }\\alpha\\) to \\(0,625\\) (albo \\(\\frac{5}{8}\\)).\n            </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                Teraz mamy użyć tablic trygonometrycznych, aby oszacować wartość kąta \\(\\alpha\\) z dokładnością do \\(1^{\\circ}\\). Poszukajmy w tablicach wartości tangensa bliskiej \\(0,625\\).\n            </p>"
    },
