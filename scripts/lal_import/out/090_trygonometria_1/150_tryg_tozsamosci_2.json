    },
    {
      "type": "text",
      "body": "\n                    \\(\\text{ctg }\\alpha=y\\)\n                "
    },
    {
      "type": "text",
      "body": "\n                    \\(\\text{ctg }\\alpha=x\\)\n                "
    },
    {
      "type": "text",
