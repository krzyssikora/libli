    },
    {
      "type": "text",
      "body": "<p>\n        Silnia może być zdefiniowana rekurencyjnie:\n    </p>"
    },
    {
      "type": "text",
      "body": "\n        \\[\n        n!=\\begin{cases}\n        1&amp;\\text{jeśli }n=0\\\\\n        n\\cdot(n-1)!&amp;\\text{jeśli }n\\gt 0\n        \\end{cases}\n        \\]\n    "
    },
    {
      "type": "text",
      "body": "<p>\n    Z definicji rekurencyjnej widzimy, że:\n</p>"
    },
    {
      "type": "text",
      "body": "\n    \\[\n    \\begin{align}\n    0!&amp;=1&amp;\\text{warunek początkowy, dla }n=0\\\\\n    1!&amp;=1\\cdot 0!=1\\cdot 1=\\color{orange}{1}\\\\\n    2!&amp;=2\\cdot 1!=2\\cdot \\color{orange}{1}=\\color{red}{2}\\\\\n    3!&amp;=3\\cdot 2!=3\\cdot \\color{red}{2}=\\color{violet}{6}\\\\\n    4!&amp;=4\\cdot 3!=4\\cdot \\color{violet}{6}=\\color{blue}{24}\\\\\n    5!&amp;=5\\cdot 4!=5\\cdot \\color{blue}{24}=120&amp;\\text{itd.}\n    \\end{align}\n    \\]\n"
    }
  ],
