{
  "elements": [
    {
      "type": "text",
      "body": "<p><strong>Przykład</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Na ile sposobów możemy wybrać trzy obiekty spośród pięciu?\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "przeczytaj rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                    Oznaczmy te pięć obiektów literami: \n                    <span style=\"color: red; font-weight: bold;\">A</span>, \n                    <span style=\"color: blue; font-weight: bold;\">B</span>, \n                    <span style=\"color: green; font-weight: bold;\">C</span>, \n                    <span style=\"color: orange; font-weight: bold;\">D</span>, \n                    <span style=\"color: black; font-weight: bold;\">E</span>.\n                </p>"
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                        Czy to przypadkiem nie jest tak, że \n                    </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>pierwszy obiekt wybieramy na \\(5\\) sposobów,</li>\n<li>drugi obiekt wybieramy na \\(4\\) sposoby,</li>\n<li>trzeci obiekt wybieramy na \\(3\\) sposoby?</li>\n</ul>"
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                        Czyli odpowiedzią na to pytanie byłaby liczba \\(3\\)-wyrazowych wariacji <strong>bez powtórzeń</strong> ze zbioru \\(5\\)-elementowego?\n                    </p>"
        },
        {
          "type": "text",
          "body": "<p>\\[\n                    V_5^3=\\frac{5!}{(5-3)!}=5\\cdot 4\\cdot 3=60\n                    \\]\n                    ?</p>"
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                        Nie całkiem... \n                    </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                        Dlaczego? Wypiszmy wszystkie takie wariacje:\n                    </p>"
        },
