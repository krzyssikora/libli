    {
      "type": "text",
      "body": "<p>\n<strong>Permutacja</strong> to ustawienie \\(n\\) obiektów w rzędzie.\n    </p>"
    },
    {
      "type": "text",
      "body": "<p>\n        Liczba permutacji zbioru \\(n\\)-elementowego jest równa \\(n!\\).\n    </p>"
    },
    {
