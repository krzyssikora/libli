    {
      "type": "text",
      "body": "<p>\n    mija się z celem, bo odpowiedź będzie brzmiała po prostu \"\\(n!\\)\".\n</p>"
    },
    {
      "type": "text",
      "body": "<p>\n    Rozwiążmy kilka trochę bardziej wymagających zadań. \n</p>"
