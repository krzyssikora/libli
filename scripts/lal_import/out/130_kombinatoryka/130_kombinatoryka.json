    {
      "type": "text",
      "body": "\n<p>\n            W grupie jest pięć dziewcząt i czterech chłopców.\n        </p>\n<p>\n            Na ile sposobów możemy ustawić wszystkich dziewięcioro w szeregu, ale tak, aby zarówno wszyscy chłopcy stali razem, jak i wszystkie dziewczęta stały razem.\n        </p>\n"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "body": "\n\n<div class=\"switch_steps\">\n<div class=\"switch_step\">\n                Skoro zarówno chłopcy i dziewczęta mają stać razem, to znaczy, że musimy ustawić albo najpierw dziewczęta, a potem chłopców:\n                <figure>\n<img src=\"static/dziewczeta_chlopcy.png\" style=\"max-width: 80%;\"/>\n</figure>\n                albo najpierw chłopców, a potem dziewczęta:\n                <figure>\n<img src=\"static/chlopcy_dziewczeta.png\" style=\"max-width: 80%;\"/>\n</figure>\n<div class=\"switch_line\">\n                    W każdej z tych dwóch sytuacji dziewczęta możemy ustawić na\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(4!\\) sposobów</div>\n<div class=\"switch_value\">\\(5!\\) sposobów</div>\n<div class=\"switch_value\">\\(9!\\) sposobów</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n                    Podobnie w każdej z tych dwóch sytuacji chłopców możemy ustawić na\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(4!\\) sposobów</div>\n<div class=\"switch_value\">\\(5!\\) sposobów</div>\n<div class=\"switch_value\">\\(9!\\) sposobów</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n                    I dlatego wszystkich ustawień dziewcząt i chłopców jest\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(2\\cdot 5!\\cdot 4!\\)</div>\n<div class=\"switch_value\">\\(5!\\cdot 4!\\)</div>\n<div class=\"switch_value\">\\(9!\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"table_wrapper\">\n<table class=\"my_table_noborder narrow_table\">\n<tr>\n<td>sytuacji</td>\n<td></td>\n<td>ustawień<br/>dziewcząt</td>\n<td></td>\n<td>ustawień<br/>chłopców</td>\n<td></td>\n</tr>\n<tr>\n<td>\\(\\downarrow\\)</td>\n<td></td>\n<td>\\(\\downarrow\\)</td>\n<td></td>\n<td>\\(\\downarrow\\)</td>\n<td></td>\n</tr>\n<tr>\n<td>\\(2\\)</td>\n<td>\\(\\cdot\\)</td>\n<td>\\(5!\\)</td>\n<td>\\(\\cdot\\)</td>\n<td>\\(4!\\)</td>\n<td>\\(=5\\,760\\)</td>\n</tr>\n</table>\n</div>\n</div>\n</div>\n"
    },
