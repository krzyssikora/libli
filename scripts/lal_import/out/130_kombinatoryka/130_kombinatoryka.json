    {
      "type": "text",
      "body": "\n<p>\n            W grupie jest pięć dziewcząt i czterech chłopców.\n        </p>\n<p>\n            Na ile sposobów możemy ustawić wszystkich dziewięcioro w szeregu, ale tak, aby żadna dziewczynka nie stała obok innej dziewczynki.\n        </p>\n"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "body": "\n\n<div class=\"switch_steps\">\n<div class=\"switch_step\">\n                Skoro żadna dziewczynka nie może stać obok innej dziewczynki, to oznacza, że dziewczynki i chłopcy muszą stać na przemian:\n                <figure>\n<img src=\"static/dz_ch_dz_ch_dz_ch_dz_ch_dz.png\" style=\"max-width: 80%;\"/>\n</figure>\n                Miejsca, w których mają \"stać\" dziewczęta i chłopcy są więc ustalone. \n                <div class=\"switch_line\">\n                    Dziewczęta możemy ustawić na przeznaczonych dla nich miejscach na\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(4!\\) sposobów</div>\n<div class=\"switch_value\">\\(5!\\) sposobów</div>\n<div class=\"switch_value\">\\(9!\\) sposobów</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n                    Podobnie chłopców możemy ustawić na przeznaczonych dla nich miejscach na\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(4!\\) sposobów</div>\n<div class=\"switch_value\">\\(5!\\) sposobów</div>\n<div class=\"switch_value\">\\(9!\\) sposobów</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n<div class=\"switch_line\">\n                    I dlatego wszystkich ustawień dziewcząt i chłopców jest\n                    <div class=\"switch_value\">&gt;&gt; wybierz &gt;&gt;</div>\n<div class=\"switch_value\">\\(2\\cdot 5!\\cdot 4!\\)</div>\n<div class=\"switch_value\">\\(5!\\cdot 4!\\)</div>\n<div class=\"switch_value\">\\(9!\\)</div>\n<div class=\"switch_show_next ks_button\">zatwierdź</div>.\n                </div>\n</div>\n<div class=\"switch_step hidden\">\n                \\(5!\\cdot 4!=2\\,880\\)\n            </div>\n</div>\n"
    },
