          "type": "switch_gate",
          "stem": "\n\n\n\n\n\n￿0￿.\n                ",
          "options": [
            "9 cyfr",
            "5 cyfr",
            "4 cyfry",
            "10 cyfr"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    A dokładniej jedną z: \\(1, 3, 5, 7, 9\\).\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    I dlatego kiedy pierwsza cyfra jest parzysta, mamy\n                    \n\n\n\n￿0￿.\n                ",
