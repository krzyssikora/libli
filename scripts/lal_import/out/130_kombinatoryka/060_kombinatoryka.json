            },
            {
              "type": "text",
              "body": "<ul>\n<li>\n                                Jeśli na końcu jest \\(0\\), to:\n                                <ul>\n<li>\n                                        na ostatniej pozycji mamy wybór jednej cyfry (czyli \\(0\\) - skromny wybór),\n                                    </li>\n<li>\n                                        na pierwszej pozycji mamy wybór z dziewięciu cyfr.\n                                    </li>\n</ul>\n</li>\n<li>\n                                Jeśli na końcu jest \\(2\\), \\(4\\), \\(6\\) lub \\(8\\), to:\n                                <ul>\n<li>\n                                        na ostatniej pozycji mamy wybór z czterech cyfr (\\(2\\), \\(4\\), \\(6\\), \\(8\\)),\n                                    </li>\n<li>\n                                        na pierwszej pozycji mamy wybór z ośmiu cyfr.\n                                    </li>\n</ul>\n</li>\n</ul>"
            },
