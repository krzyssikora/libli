{
  "elements": [
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Czy proste \\(7x-2y+3=0\\) i \\(14x-4y-17=0\\) są równoległe?\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Uzasadnij odpowiedź.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "odpowiedź",
      "elements": [
        {
          "type": "text",
          "body": "<p>Tak, bo \\(\\frac{7}{-2}=\\frac{14}{-4}\\).</p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Czy proste \\(6x+10y+3=0\\) i \\(9x-15y-4=0\\) są równoległe?\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Uzasadnij odpowiedź.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "odpowiedź",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Nie. \n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Stosunek współczynników \\(x\\)-a i \\(y\\)-a z pierwszego równania to \\(\\frac{6}{10}=\\frac{3}{5}\\).\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Stosunek współczynników \\(x\\)-a i \\(y\\)-a z drugiego równania to \\(\\frac{9}{-15}=-\\frac{3}{5}\\).\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            \\(\\frac{3}{5}=-\\frac{3}{5}\\), więc proste nie są równoległe.\n        </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Czy proste \\(5x-4y+2=0\\) i \\(8x-10y-3=0\\) są prostopadłe?\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Uzasadnij odpowiedź.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "odpowiedź",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Nie, bo \\(5\\cdot 8+(-4)\\cdot(-10)=40+40\\ne 0\\).\n        </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Czy proste \\(6x+14y+15=0\\) i \\(21x-9y-10=0\\) są prostopadłe?\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Uzasadnij odpowiedź.\n        </p>"
