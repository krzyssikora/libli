        {
          "id": "t000002",
          "label": "1 (O)",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                            Prosta ma być styczna do okręgu, czyli układ równań\n                        </p>"
            },
            {
              "type": "text",
              "body": "\n                            \\[\n                            \\begin{cases}\n                            (x+5)^2+(y-6)^2=10\\\\\n                            y=mx+1\n                            \\end{cases}\n                            \\]\n                        "
            },
            {
              "type": "text",
              "body": "<p>\n                            ma <strong>dokładnie jedno</strong> rozwiązanie.\n                        </p>"
            },
            {
              "type": "reveal_gate",
              "label": "pokaż dalej"
            },
            {
              "type": "text",
              "body": "<p>\n                                Zacznijmy rozwiązywać układ równań. W tym celu podstawimy równanie prostej do równania okręgu.\n                            </p>"
            },
            {
              "type": "text",
              "body": "\n                                \\[\n                                \\begin{cases}\n                                (x+5)^2+(y-6)^2=10\\\\\n                                \\color{red}{y=mx+1}\n                                \\end{cases}\n                                \\]\n                                \\[\n                                \\Downarrow\n                                \\]\n                                \\[\n                                (x+5)^2+(\\color{red}{mx+1}-6)^2=10\n                                \\]\n                            "
            },
            {
              "type": "reveal_gate",
              "label": "pokaż dalej"
            },
            {
              "type": "text",
              "body": "<p>\n                                Uprośćmy otrzymane równanie:\n                            </p>"
            },
            {
              "type": "text",
              "body": "\n                                \\[\n                                \\begin{align}\n                                (x+5)^2+(mx+1-6)^2&amp;=10\\\\\n                                (x+5)^2+(mx-5)^2&amp;=10\\\\\n                                x^2+10x+25+m^2x^2-10mx+25-10&amp;=0\n                                \\end{align}\n                                \\]\n                            "
            },
            {
              "type": "reveal_gate",
              "label": "pokaż dalej"
            },
            {
              "type": "text",
              "body": "<p>\n                                Teraz pogrupujemy wyrazy wedle potęg \\(x\\)-ów:\n                            </p>"
            },
            {
              "type": "text",
              "body": "\n                                \\[\n                                \\begin{align}\n                                x^2+10x+25+m^2x^2-10mx+25-10&amp;=0\\\\\n                                x^2+m^2x^2+10x-10mx+25+25-10&amp;=0\\\\\n                                (1+m^2)x^2+(10-10m)x+40&amp;=0\n                                \\end{align}\n                                \\]\n                            "
            },
            {
              "type": "reveal_gate",
              "label": "pokaż dalej"
            },
            {
              "type": "text",
              "body": "<p>\n                                Otrzymaliśmy równanie kwadratowe.\n                            </p>"
            },
            {
              "type": "table",
              "data": {
                "header_row": false,
                "header_col": false,
                "border": "grid",
                "cells": [
                  [
                    {
                      "html": "\\((1+m^2)\\)",
                      "halign": "left",
                      "valign": "top"
                    },
                    {
                      "html": "\\(x^2+\\)",
                      "halign": "left",
                      "valign": "top"
                    },
                    {
                      "html": "\\((10-10m)\\)",
                      "halign": "left",
                      "valign": "top"
                    },
                    {
                      "html": "\\(x+\\)",
                      "halign": "left",
