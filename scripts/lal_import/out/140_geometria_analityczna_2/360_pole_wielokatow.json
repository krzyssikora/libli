                }
              ]
            ]
          }
        },
        {
          "type": "text",
          "body": "<p>\n                    I teraz wystarczy zauważyć, że\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                \\left(\\frac{1}{2}\\right)\\cdot (-2)=-1\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    a to oznacza, że\n                </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>bok \\(AB\\) jest prostopadły do boku \\(BC\\),</li>\n<li>bok \\(BC\\) jest prostopadły do boku \\(CD\\),</li>\n<li>bok \\(CD\\) jest prostopadły do boku \\(AD\\),</li>\n<li>bok \\(AD\\) jest prostopadły do boku \\(AB\\),</li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n                    czyli czworokąt \\(ABCD\\) jest prostokątem.\n                </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                    Jeśli nie pamiętasz, dlaczego, zeknij <a href=\"/jump_to_id/26aaae708ac34d74a461ea6f1a663322\">tutaj</a>.\n                    <!-- INTERNAL LINK -->\n</p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Dany jest trójkąt \\(ABC\\), którego wierzchołki mają współrządne: \\(A=(-4,1)\\), \\(B=(4,-3)\\) i \\(C=(5,4)\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\">\n<li>Oblicz długość odcinka \\(AB\\).</li>\n<li>Oblicz współczynnik kierunkowy prostej przechodzącej przez punkty \\(A\\) i \\(B\\).</li>\n<li>Znajdź równanie prostej przechodzącej przez punkty \\(A\\) i \\(B\\).</li>\n<li>\n                Oblicz odległość punktu \\(C\\) od tej prostej.\n            </li>\n<li>\n                Oblicz pole trójkąta \\(ABC\\).\n            </li>\n</ol>"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<ol class=\"bold\">\n<li>Oblicz długość odcinka \\(AB\\).</li>\n</ol>"
        },
        {
          "type": "text",
          "body": "<h4>Jak to zrobić?</h4>"
        },
        {
          "type": "text",
          "body": "<p>\n                    Długość odcinka \\(AB\\) o końcach \\(A=(x_A, y_A)\\) i \\(B=(x_B, y_B)\\) dana jest wzorem\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                |AB|=\\sqrt{(x_A-x_B)^2+(y_A-y_B)^2}\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    A więcej szczegółów znajdziesz <a href=\"/jump_to_id/b3c27d9a7a754655b04f52cf59cc3ac2\">tutaj</a>.\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Długość odcinka \\(AB\\) dana jest wyrażeniem\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\sqrt{(-4+4)^2+(1-3)^2}\\)",
            "\\(\\sqrt{(-4-4)^2+(1+3)^2}\\)",
            "\\(\\sqrt{(-4-4)^2-(1+3)^2}\\)"
          ],
          "answer": 1
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Uprośćmy: \\(\\sqrt{(-4-4)^2+(1+3)^2}=\\)\\(\\sqrt{(-8)^2+4^2}=\\)\\(\\sqrt{64+16}=...=\\)\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(12\\)",
            "\\(4\\sqrt{5}\\)",
            "\\(16\\sqrt{5}\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\" start=\"2\">\n<li>Oblicz współczynnik kierunkowy prostej przechodzącej przez punkty \\(A\\) i \\(B\\).</li>\n</ol>"
        },
        {
          "type": "text",
          "body": "<h4>Jak to zrobić?</h4>"
        },
        {
          "type": "text",
          "body": "<p>\n                        Współczynnik kierunkowy (nachylenie) prostej przechodzącej przez punkty \\(A=(x_A, y_A)\\) i \\(B=(x_B, y_B)\\) dany jest wyrażeniem\n                    </p>"
        },
        {
          "type": "math",
          "latex": "\n                    \\frac{y_A-y_B}{x_A-x_B}\n                    "
        },
        {
          "type": "text",
          "body": "<p>\n                        A więcej szczegółów znajdziesz <a href=\"/jump_to_id/1a55970974e24c60a34789b4b51c70bb\">tutaj</a>.\n                    </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Współczynnik kierunkowy prostej przechodzącej przez punkty \\(A\\) i \\(B\\) jest dany wyrażeniem\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{1+3}{-4-4}\\)",
            "\\(\\frac{1-3}{-4+4}\\)",
            "\\(\\frac{1-3}{4+4}\\)"
          ],
          "answer": 0
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Po uproszczeniu współczynnik keirunkowy jest równy\n                    \n\n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{1}{2}\\)",
            "\\(-\\frac{1}{2}\\)",
            "\\(-\\frac{1}{4}\\)",
            "\\(\\frac{1}{4}\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\" start=\"3\">\n<li>Znajdź równanie prostej przechodzącej przez punkty \\(A\\) i \\(B\\).</li>\n</ol>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Z tego, co ustaliliśmy, wiemy, że równanie tej prostej jest postaci \n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(y=-\\frac{1}{2}x+b\\)",
            "\\(y=ax+\\frac{1}{2}\\)",
            "\\(y=2x+b\\)"
          ],
          "answer": 0
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Aby znaleźć wartość współczynnika \\(b\\) musimy do tego równania podstawić współrzędne\n                    \n\n\n￿0￿.\n                ",
          "options": [
            "punktu \\(A\\) lub \\(B\\)",
            "punktu \\(C\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Podstawiając współrządne punktu \\(A\\) dostajemy:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                1=-\\frac{1}{2}\\cdot (-4)+b\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    Podstawiając współrządne punktu \\(B\\) dostajemy:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                -3=-\\frac{1}{2}\\cdot 4+b\n                "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Z dowolnego z tych równań wyliczamy, że\n                    \n\n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(b=-1\\)",
            "\\(b=1\\)",
            "\\(b=3\\)",
            "\\(b=-5\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\" start=\"4\">\n<li>\n                        Oblicz odległość punktu \\(C\\) od tej prostej.\n                    </li>\n</ol>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    W tym celu najpierw przekształcamy równanie prostej, \\(y=-\\frac{1}{2}x-1\\) do postaci ogólnej, otrzymując\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(x-2y-2=0\\)",
            "\\(x+2y+2=0\\)",
            "\\(x+2y+1=0\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Mamy więc znaleźć odległość punktu \\(C=(5,4)\\) od prostej o równaniu \\(x+2y+2=0\\).\n                </p>"
        },
        {
          "type": "text",
          "body": "<h4>Jak to zrobić?</h4>"
        },
        {
          "type": "text",
          "body": "<p>\n                        Odległość punkt \\((x_0, y_0)\\) od prostej \\(Ax+By+C=0\\) dana jest wyrażeniem\n                    </p>"
        },
        {
          "type": "math",
          "latex": "\n                    \\frac{|Ax_0+By_0+C|}{\\sqrt{A^2+B^2}}\n                    "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Odległość punktu \\(C\\) od prostej przechodzącej przez punkty \\(A\\) i \\(B\\) dana jest wyrażeniem\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{|5+2\\cdot 4+2|}{\\sqrt{1^2+2^2}}\\)",
            "\\(\\frac{|5+2\\cdot 4+2|}{\\sqrt{2^2+2^2}}\\)",
            "\\(\\frac{|2\\cdot 5+4+2|}{\\sqrt{1^2+2^2}}\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Uprośćmy:\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\[\n                    \\begin{align}\n                    \\frac{|5+2\\cdot 4+2|}{\\sqrt{1^2+2^2}}&amp;=\\frac{|5+8+2|}{\\sqrt{1+4}}=\\\\\n                    &amp;=\\frac{|15|}{\\sqrt{5}}=\\\\\n                    &amp;=\\frac{15}{\\sqrt{5}}\n                    \\end{align}\n                    \\]\n                "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Usuwając niewymierność z mianownika obliczamy, że odległość punktu \\(C\\) od prostej przechodzącej przez punkty \\(A\\) i \\(B\\) jest równa\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(15\\sqrt{5}\\)",
            "\\(5\\sqrt{5}\\)",
            "\\(3\\sqrt{5}\\)"
          ],
          "answer": 2
        },
        {
          "type": "text",
          "body": "<p>\n                    Podsumujmy:\n                </p>"
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\">\n<li>Długość odcinka \\(AB\\) jest równa \\(4\\sqrt{5}\\).</li>\n<li><s>Współczynnik kierunkowy prostej przechodzącej przez punkty \\(A\\) i \\(B\\) to \\(-\\frac{1}{2}\\).</s></li>\n<li><s>Równanie prostej przechodzącej przez punkty \\(A\\) i \\(B\\) to \\(x+2y+2=0\\).</s></li>\n<li>\n                        Odległość punktu \\(C\\) od tej prostej jest równa \\(3\\sqrt{5}\\).\n                    </li>\n</ol>"
        },
        {
          "type": "text",
          "body": "<p>\n                    Punkty <strong>2</strong> i <strong>3</strong> są skreślone nie dlatego, że coś z nimi nie tak, lecz dlatego, że do ostatniego kroku rozwiązania potrzebujemy tylko <strong>1</strong> i <strong>4</strong>.\n                </p>"
        },
        {
          "type": "image",
          "media_src": "static/geometria_analityczna_2_zadanie_940.png",
          "alt": "",
          "figcaption": ""
        },
        {
          "type": "text",
          "body": "<ol class=\"bold\" start=\"5\">\n<li>\n                        Oblicz pole trójkąta \\(ABC\\).\n                    </li>\n</ol>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Pole trójkąta \\(ABC\\) jest równe\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(\\frac{1}{2}\\cdot 4\\sqrt{5}\\cdot 3\\sqrt{5}\\)",
            "\\(4\\sqrt{5}\\cdot 3\\sqrt{5}\\)",
            "\\((4\\sqrt{5})^2 + (3\\sqrt{5})^2\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
          "body": "<p>\n                    Długość odcinka \\(AB\\) to podstawa trójkąta, a odległość punktu \\(C\\) od boku \\(AB\\) to jego wysokość, więc pole trójkąta, \\(P_{\\Delta}\\) jest równe:\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\[\n                    \\begin{align}\n                    P_{\\Delta}&amp;=\\frac{1}{2}\\cdot 4\\sqrt{5}\\cdot 3\\sqrt{5}=\\\\\n                    &amp;=\\frac{1}{2}\\cdot 4\\cdot 3\\cdot \\sqrt{5}\\cdot \\sqrt{5}\n                    \\end{align}\n                    \\]\n                "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Czyli ostatecznie pole trójkąta to\n                    \n\n\n￿0￿.\n                ",
          "options": [
            "\\(15\\)",
            "\\(30\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "\n                    \\[\n                    \\begin{align}\n                    P_{\\Delta}&amp;=\\frac{1}{2}\\cdot 4\\sqrt{5}\\cdot 3\\sqrt{5}=\\\\\n                    &amp;=\\frac{1}{2}\\cdot 4\\cdot 3\\cdot \\sqrt{5}\\cdot \\sqrt{5}=\\\\\n                    &amp;=2\\cdot 3\\cdot 5=30\n                    \\end{align}\n                    \\]\n                "
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            W równoległoboku \\(ABCD\\) dane są współrządne wierzchołków \\(A=(-7,-1)\\), \\(B=(5,-5)\\) i \\(D=(-4,3)\\).\n        </p>"
    },
    {
      "type": "image",
      "media_src": "static/geometria_analityczna_2_zadanie_950_1.png",
      "alt": "",
      "figcaption": ""
    },
    {
      "type": "text",
      "body": "<p>\n            Oblicz pole równoległoboku.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                    Przyjmijmy, że długości boków równoległoboku to \\(a\\) i \\(b\\), a wysokość opadająca na bok \\(a\\) to \\(h\\).\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Wówczas pole równoległoboku, \\(P\\), możemy obliczyć ze wzoru \n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(P=a\\cdot b\\)",
            "\\(P=a\\cdot h\\)",
            "\\(P=b\\cdot h\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Zacznijmy od długości boku \\(AB\\).\n                </p>"
        },
        {
          "type": "text",
          "body": "<h4>Pamiętasz wzór?</h4>"
        },
        {
          "type": "text",
          "body": "<p>\n                        Jeśli \\(A=(x_A, y_A)\\) i \\(B=(x_B, y_B)\\) to długość odcinka \\(AB\\) dana jest wzorem\n                    </p>"
        },
        {
          "type": "text",
          "body": "\n                        \\[\n                        |AB|=\\sqrt{(x_A-x_B)^2+(y_A-y_B)^2}\n                        \\]\n                    "
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Jest ona określona wyrażeniem\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(|AB|=\\sqrt{(-7-5)^2+(-1+5)^2}\\)",
            "\\(|AB|=\\sqrt{(-7+5)^2+(-1-5)^2}\\)",
            "\\(|AB|=\\sqrt{(-7+1)^2+(5+5)^2}\\)"
          ],
          "answer": 0
        },
        {
          "type": "text",
