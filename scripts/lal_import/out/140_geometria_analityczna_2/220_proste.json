        {
          "type": "text",
          "body": "<p>\n                    znajdźmy wartość współczynnika \\(D\\), a na zakończenie doprowadzimy równanie do żądanej postaci.\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Aby znaleźć wartość współczynnika \\(D\\) musimy\n                    \n\n\n￿0￿.\n                ",
          "options": [
