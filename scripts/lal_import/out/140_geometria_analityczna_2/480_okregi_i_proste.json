          "elements": [
            {
              "type": "switch_gate",
              "stem": "\n                            Środek okręgu to punkt \n                            \n\n\n\n￿0￿.\n                        ",
              "options": [
                "\\((-5,2)\\)",
                "\\((5,-2)\\)",
                "\\((2,-6)\\)"
              ],
              "answer": 1
            },
            {
              "type": "text",
              "body": "<p>\n                            Zacznijmy od współczynnika kierunkowego prostej przechodzącej przez punkty \\((2,-6)\\) oraz środek okręgu \\((5,-2)\\).\n                        </p>"
            },
            {
              "type": "spoiler",
              "label": "pamiętasz, jak to zrobić?",
              "elements": [
                {
                  "type": "text",
                  "body": "<p>\n                                    Nachylenie prostej przechodzącej przez punkty\n                                </p>"
                },
                {
                  "type": "text",
                  "body": "\n                                    \\[\n                                    A=(x_A, y_A)\\quad\\text{oraz}\\quad B=(x_B, y_B)\n                                    \\]    \n                                "
                },
                {
                  "type": "text",
                  "body": "<p>\n                                    dane jest wyrażeniem\n                                </p>"
                },
                {
                  "type": "text",
                  "body": "\n                                    \\[\n                                    \\left(\\frac{\\text{skok}}{\\text{krok}}\\right)\\quad =\\frac{y_B-y_A}{x_B-x_A}\n                                    \\]\n                                "
                },
                {
                  "type": "image",
                  "media_src": "static/funkcja_liniowa_nachylenie_prostej_przez_2_punkty.png",
                  "alt": "",
                  "figcaption": ""
                }
              ]
            },
            {
              "type": "switch_gate",
              "stem": "\n                            Nachylenie tej prostej jest równe \n                            \n\n\n\n\n￿0￿.\n                        ",
              "options": [
                "\\(\\frac{4}{3}\\)",
                "\\(\\frac{3}{4}\\)",
                "\\(-\\frac{8}{7}\\)",
                "\\(-\\frac{7}{8}\\)"
              ],
              "answer": 0
            },
            {
              "type": "text",
              "body": "<p>\n                            Styczna do okręgu w punkcie \\((2,-6)\\) jest <strong>prostopadła</strong> do promienia łączącego środek okręgu z tym punktem.\n                        </p>"
            },
            {
              "type": "switch_gate",
              "stem": "\n                            Dlatego współczynnik kierunkowy stycznej jest równy\n                            \n\n\n\n\n￿0￿.\n                        ",
              "options": [
                "\\(\\frac{4}{3}\\)",
                "\\(-\\frac{3}{4}\\)",
                "\\(-\\frac{4}{3}\\)",
                "\\(\\frac{3}{4}\\)"
              ],
              "answer": 1
            },
            {
              "type": "text",
              "body": "<p>\n                            Tak więc równanie stycznej jest postaci\n                        </p>"
            },
            {
              "type": "math",
              "latex": "\n                        y=-\\frac{3}{4}x+b\n                        "
            },
            {
              "type": "switch_gate",
              "stem": "\n                            Styczna przechodzi przez punkt \\((2,-6)\\), więc \n                            \n\n\n\n￿0￿.\n                        ",
              "options": [
                "\\(-6=-\\frac{3}{4}\\cdot 2+b\\)",
                "\\(2=-\\frac{3}{4}\\cdot (-6)+b\\)",
                "\\(b=-6\\)"
              ],
              "answer": 0
