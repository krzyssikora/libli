    {
      "type": "spoiler",
      "label": "odpowiedź",
      "body": "\n\n<p>\n            \\(a=-3\\) lub \\(a=7\\)\n        </p>\n<figure>\n<img src=\"static/geometria_analityczna_2_zadanie_1240.png\" style=\"max-height: 250px;\"/>\n</figure>\n"
