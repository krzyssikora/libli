              "type": "math",
              "latex": "\n                            \\begin{align}\n                            y^2-6y+9&=0\\\\\n                            (y-3)^2&=0\\\\\n                            y-3&=0\\\\\n                            y&=3\n                            \\end{align}\n                            "
