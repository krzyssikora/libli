    {
      "type": "text",
      "body": "<p>\n            Dany jest odcinek \\(AB\\) o końcach\n        </p>"
    },
    {
      "type": "text",
      "body": "\n            \\(A=(x_A, y_A)\\) i \\(B=(x_B, y_B)\\).\n        "
    },
    {
      "type": "text",
      "body": "<p>\n            Jaki jest wzór na środek odcinka \\(AB\\).\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "sprawdź",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                Jeśli \\(A=(x_A, , to y_A)\\) i \\(B=(x_B, y_B)\\) to współrzędne punktu \\(S\\), środka odcinka \\(AB\\) dane są wzorem\n            </p>"
        },
        {
          "type": "math",
          "latex": "\n            S=\\left(\\frac{x_A+x_B}{2},\\frac{y_A+y_B}{2}\\right)\n            "
        },
        {
          "type": "text",
          "body": "<p>\n                Więcej na temat tego wzoru możesz przypomnieć sobie <a href=\"/jump_to_id/676a5dda58f64946a6a4747c68ad5157\">tutaj</a>.\n            </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Mając dane współrzędne końców odcinka \\(AB\\), znajdź współrzędne środka odcinka.\n        </p>"
    },
    {
