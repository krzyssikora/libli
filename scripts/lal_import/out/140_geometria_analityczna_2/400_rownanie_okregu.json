    {
      "type": "text",
      "body": "\n<p>\n            Co możemy powiedzieć o punktach \\(A\\), \\(B\\) i \\(C\\), które leżą w jednakowej odległości od punktu \\(S\\)?\n        </p>\n<figure>\n<img src=\"static/geometria_analityczna_2_rownanie_okregu_intro_1.png\" style=\"max-height: 350px;\"/>\n</figure>\n"
    },
    {
      "type": "text",
      "body": "pokaż dalej"
    },
    {
      "type": "text",
      "body": "<p>\n                A gdyby narysować takich punktów więcej? Na przykład \\(15\\)?\n            </p>"
    },
    {
      "type": "image",
      "media_src": "static/geometria_analityczna_2_rownanie_okregu_intro_2.png",
      "alt": "",
      "figcaption": ""
    },
    {
      "type": "text",
      "body": "pokaż dalej"
    },
    {
      "type": "text",
      "body": "<p>\n                Albo \\(25\\)?\n            </p>"
    },
    {
      "type": "image",
      "media_src": "static/geometria_analityczna_2_rownanie_okregu_intro_3.png",
      "alt": "",
