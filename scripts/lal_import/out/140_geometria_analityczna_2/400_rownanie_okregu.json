          ],
          [
            {
              "html": "\\(\\color{blue}{A=(1, 5)}\\)",
              "halign": "left",
              "valign": "top"
            },
            {
              "html": "\\(\\sqrt{(\\color{blue}{1}-\\color{red}{(-3)})^2+(\\color{blue}{5}-\\color{red}{2})^2}=5\\)",
              "halign": "left",
              "valign": "top"
