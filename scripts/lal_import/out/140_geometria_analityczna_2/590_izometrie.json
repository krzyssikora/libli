    },
    {
      "type": "text",
      "body": "<p>\n            Znajdź równanie obrazu prostej o równaniu \\(y=-\\frac{1}{3}x+2\\) w przekształceniu \\(P\\) zdefiniowanym wzorem\n        </p>"
    },
    {
      "type": "math",
      "latex": "\n        P(x,y)=(x, -y)\n        "
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "switch_gate",
          "stem": "\n                    Przekształcenie \\(P\\) to symetria względem\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "osi \\(OX\\)",
            "osi \\(OY\\)",
            "punktu \\((0,0)\\)"
          ],
          "answer": 0
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Równanie prostej \\(y=-\\frac{1}{3}x+2\\) odbitej w symetrii względem osi \\(OX\\) ma postać\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(y=\\frac{1}{3}x+2\\)",
            "\\(y=\\frac{1}{3}x-2\\)",
            "\\(y=-\\frac{1}{3}x-2\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Wykres funkcji \\(y=f(x)\\) po odbiciu w osi \\(OX\\) przyjmuje równanie \\(y=-f(x)\\), więc prosta \\(y=-\\frac{1}{3}x+2\\) zmienia się w \\(y=-(-\\frac{1}{3}x+2)\\), czyli w \\(y=\\frac{1}{3}x-2\\).\n                </p>"
        },
        {
          "type": "image",
