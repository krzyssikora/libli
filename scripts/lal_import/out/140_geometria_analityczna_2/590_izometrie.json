            "\\((5,-1)\\)"
          ],
          "answer": 1
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Po przesunięciu o wektor \\([-7,3]\\) środek będzie w punkcie\n                    \n\n\n￿0￿.\n                ",
          "options": [
            "\\((12, 4)\\)",
            "\\((-2, 2)\\)"
          ],
          "answer": 1
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Dlatego równanie przesuniętego okręgu to\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\((x-2)^2+(y+2)^2=49\\)",
            "\\((x+2)^2+(y-2)^2=49\\)",
            "\\((x-2)^2+(y-2)^2=49\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Obraz okrągu o równaniu \\((x-5)^2+(y+1)^2=49\\) w przekształceniu \\(P\\) to okrąg o równaniu \\((x+2)^2+(y-2)^2=49\\).\n                </p>"
        },
        {
          "type": "image",
