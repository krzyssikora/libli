        },
        {
          "type": "switch_gate",
          "stem": "\n                    Aby znaleźć wartość współczynnika \\(b\\), podstawiamy współrzędne punktu \\((6,2)\\) otrzymując równanie\n                    \n\n\n\n￿0￿.\n                ",
