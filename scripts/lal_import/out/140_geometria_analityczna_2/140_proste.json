{
  "elements": [
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n        Znajdź równanie prostej nachylonej pod kątem \\(60^{\\circ}\\) do osi \\(OX\\) i przechodzącej przez punkt \\((3, 2)\\).\n    "
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>Przyjmijmy, że równanie szukanej prostej to \\(y=ax+b\\).</p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Skoro kąt nachylenia prostej do osi \\(OX\\) jest równy \\(60^{\\circ}\\), to \n                    \n\n\n\n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a=\\text{tg}\\,60^{\\circ}\\)",
            "\\(b=\\text{tg}\\,60^{\\circ}\\)",
            "\\(a=\\sin 60^{\\circ}\\)",
            "\\(b=\\sin 60^{\\circ}\\)",
            "\\(a=\\cos 60^{\\circ}\\)",
            "\\(b=\\cos 60^{\\circ}\\)"
          ],
          "answer": 0
        },
        {
          "type": "switch_gate",
          "stem": "\n                    \\(a=\\text{tg}\\,60^{\\circ}\\), czyli \n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a=\\frac{1}{\\sqrt{3}}\\)",
            "\\(a=1\\)",
            "\\(a=\\sqrt{3}\\)"
          ],
          "answer": 2
        },
        {
          "type": "text",
          "body": "<p>\n                    Równanie szukanej prostej ma postać\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                y=\\sqrt{3}\\cdot x+b\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    Aby znaleźć współczynnik \\(b\\), musimy do tego równania podstawić współrzędne punktu \\((3, 2)\\).\n                </p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Otrzymujemy\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(3=\\sqrt{3}\\cdot 2+b\\)",
            "\\(2=\\sqrt{3}\\cdot 3+b\\)",
            "\\(2=\\sqrt{3}\\cdot b+3\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    I dlatego\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                b=2-3\\sqrt{3}\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    więc szukane równanie prostej ma postać\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                y=\\sqrt{3}\\cdot x+2-3\\sqrt{3}\n                "
        }
      ]
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n        Znajdź równanie prostej nachylonej pod kątem \\(135^{\\circ}\\) do osi \\(OX\\) i przechodzącej przez punkt \\((-4,7)\\).\n    "
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>Przyjmijmy, że równanie szukanej prostej to \\(y=ax+b\\).</p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    Kąt nachylenia prostej do osi \\(OX\\) jest równy \\(135^{\\circ}\\), więc\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(b=\\text{tg}\\,135^{\\circ}\\)",
            "\\(a=\\text{tg}\\,135^{\\circ}\\)",
            "\\(a=\\sin 135^{\\circ}\\)"
          ],
          "answer": 1
        },
        {
          "type": "switch_gate",
          "stem": "\n                    \\(a=\\text{tg}\\,135^{\\circ}\\), czyli\n                    \n\n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a=1\\)",
            "\\(a=-1\\)",
            "\\(a=-\\sqrt{2}\\)",
            "\\(a=\\sqrt{2}\\)"
          ],
          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>\n                    Skoro \\(a-=1\\), to równanie prostej jest postaci\n                </p>"
