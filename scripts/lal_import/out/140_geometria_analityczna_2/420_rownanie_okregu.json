        }
      ]
    },
    {
      "type": "spoiler",
      "label": "jak znaleźć promień",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Stała po prawej stronie równania okręgu to <strong>kwadrat promienia</strong>.\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Tak więc na przykład dla równania \\((\\dots)^2+(\\dots)^2=50\\) kwadrat promienia jest równy\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        r^2=50\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            czyli\n        </p>"
        },
        {
          "type": "text",
          "body": "\n            \\[\n            \\begin{align}\n            r&amp;=\\sqrt{50}=\\\\\n            &amp;=\\sqrt{25\\cdot 2}=\\\\\n            &amp;=5\\sqrt{2}\n            \\end{align}\n            \\]\n        "
        },
        {
          "type": "text",
          "body": "<p>\n<small>\n                Pamiętaj, że promień okręgu musi być liczbą większą od zera, więc nie rozpatrujemy rozwiązania \\(r=-5\\sqrt{2}\\).\n            </small>\n</p>"
        }
      ]
    },
