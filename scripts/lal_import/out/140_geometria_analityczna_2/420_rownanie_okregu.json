{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n        Równanie okręgu o środku w punkcie \\((a,b)\\) i promieniu \\(r\\) jest postaci\n    </p>"
    },
    {
      "type": "text",
      "body": "\n        \\[\n        (x-a)^2+(y-b)^2=r^2\n        \\]\n    "
    },
    {
      "type": "text",
      "body": "<p><strong>Przykład</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Jakie są środek i promień okręgu o podanym równaniu?\n        </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\">\n<li>\n                \\((x+3)^2+(y+7)^2=49\\)\n            </li>\n<li>\n                \\((x+4)^2+(y-3)^2=48\\)\n            </li>\n<li>\n                \\((x-5)^2+y^2=45\\)\n            </li>\n<li>\n                \\(x^2+(y+6)^2=44\\)\n            </li>\n</ol>"
    },
    {
      "type": "spoiler",
      "label": "jak znaleźć środek?",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            W równaniu okręgu część ze zmienną \\(x\\) ma postać\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        (x-a)^2+\\dots\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            czyli od zmiennej \\(x\\) <strong>odejmujemy</strong> współrzędną \\(x\\)-ową środka okręgu.\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Jeśli więc fragment równania ze zmienną \\(x\\) jest postaci\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul>\n<li>\n<p>\n<strong>\\((x-\\color{red}{5})^2\\)</strong>\n</p>\n<p>\n                    wspórzędna \\(x\\)-owa środka jest równa \\(\\color{red}{5}\\).\n                </p>\n</li>\n<li>\n<p>\n<strong>\\((x+4)^2\\)</strong>\n</p>\n<p>\n                    Jest to wyrażenie równoważne\n                </p>\n<div class=\"table_wrapper\">\n                    \\[\n                    (x+4)^2=(x-\\color{red}{(-4)})^2\n                    \\]\n                </div>\n<p>\n                    więc wspórzędna \\(x\\)-owa środka jest równa \\(\\color{red}{-4}\\).\n                </p>\n</li>\n<li>\n<p>\n<strong>\\(x^2\\)</strong>\n</p>\n<p>\n                    Jest to wyrażenie równoważne\n                </p>\n<div class=\"table_wrapper\">\n                    \\[\n                    x^2=(x-\\color{red}{0})^2\n                    \\]\n                </div>\n<p>\n                    więc wspórzędna \\(x\\)-owa środka jest równa \\(\\color{red}{0}\\).\n                </p>\n</li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Identycznie jest ze współrzędną \\(y\\)-ową środka.\n        </p>"
        },
        {
          "type": "table",
          "data": {
            "header_row": true,
            "header_col": false,
            "border": "grid",
            "cells": [
              [
                {
                  "html": "wyrażenie",
                  "halign": "left",
                  "valign": "top"
                },
