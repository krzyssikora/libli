    {
      "type": "text",
      "body": "<p>Dla koła o promieniu \\(r\\):</p>"
    },
    {
      "type": "text",
      "body": "<ul class=\"nolist\">\n<li>\n</li>\n<li>\n            obwód = \\(2\\pi r\\)\n        </li>\n<li>\n</li>\n<li>\n            pole = \\(\\pi r^2\\)\n        </li>\n</ul>"
    },
    {
      "type": "text",
      "body": "<p>Dla wycinka tego koła o kącie środkowym \\(\\alpha\\):</p>"
    },
    {
      "type": "text",
      "body": "<ul class=\"nolist\">\n<li>\n</li>\n<li>\n            długość łuku = \\(d=\\frac{\\alpha}{180^{\\circ}}\\cdot\\pi r\\)\n        </li>\n<li>\n</li>\n<li>\n            pole wycinka = \\(\\frac{\\alpha}{360^{\\circ}}\\cdot \\pi r^2\\quad = \\frac{d}{2}\\cdot r\\)\n        </li>\n</ul>"
    },
