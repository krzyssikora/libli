          "figcaption": ""
        },
        {
          "type": "text",
          "body": "<h4>gdy kąt \\(A\\) jest rozwarty</h4>"
        },
        {
          "type": "image",
          "media_src": "static/tw_cosinusow_dowod_2_2.png",
          "alt": "twierdzenie cosinusów",
