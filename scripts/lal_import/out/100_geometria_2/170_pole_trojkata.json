            }
          ],
          [
            {
              "html": "<strong>\n                        1.\n                    </strong>",
              "halign": "left",
              "valign": "top"
            },
            {
              "html": "\\(P=\\frac{1}{2}ah\\)",
              "halign": "left",
              "valign": "top"
            },
            {
              "html": "\\(a\\) - podstawa, \\(h\\) - wysokość",
              "halign": "left",
