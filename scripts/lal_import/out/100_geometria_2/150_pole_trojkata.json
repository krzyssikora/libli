{
  "elements": [
    {
      "type": "text",
      "body": "<p>Przypomnijmy sobie wszystkie wzory na pole trójkąta, \\(P\\), o jakich dotąd mówiliśmy:</p>"
    },
    {
      "type": "table",
      "data": {
        "header_row": true,
