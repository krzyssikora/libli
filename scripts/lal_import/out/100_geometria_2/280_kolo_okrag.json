      "body": "<p>jest równa</p>"
    },
    {
      "type": "text",
      "body": "\n                        &gt;&gt; wybierz &gt;&gt;\n                    "
    },
    {
      "type": "text",
      "body": "\n                        \\(2,5\\pi\\) cm\n                    "
    },
    {
