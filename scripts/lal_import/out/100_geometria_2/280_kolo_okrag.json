        "\\(10\\pi\\) cm",
        "\\(10\\) cm"
      ],
      "answer": 2
    },
    {
      "type": "switch_gate",
      "stem": "\n\n\n                Obwód koła jest natomiast równy\n                \n\n\n\n\n￿0￿\n                .\n                \n",
