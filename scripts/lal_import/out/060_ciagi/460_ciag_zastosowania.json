{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n    I wreszcie trzecie zadanie łączące ciąg arytmetyczny z geometrycznym.\n</p>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Ciąg \\((a_n)\\) jest ciągiem arytmetycznym o pierwszym wyrazie równym \\(2\\) i różnicy \\(3\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Ciąg \\((b_n)\\) zdefiniowany jest równaniem ogólnym:\n        </p>"
    },
    {
      "type": "text",
      "body": "\n            \\[\n            b_n=2^{a_n},\\quad\\text{ dla }n\\in\\mathbb{N}^{+}\n            \\]\n        "
    },
    {
      "type": "text",
      "body": "<p>\n            Udowodnij, że ciąg \\((b_n)\\) jest geometryczny i znajdź liczbę naturalną \\(k\\) taką, że suma pierwszych \\(k\\) wyrazów ciągu \\(b_n\\) jest równa \\(2340\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<h4>rozwiązanie</h4>"
    },
    {
