          "answer": 1
        },
        {
          "type": "text",
          "body": "<p>Rozwiązując równanie\n                \\[\n                \\begin{align}\n                159&=a_1+39\\cdot 4\\\\\n                a_1&=159-39\\cdot 4\\\\\n                \\end{align}\n                \\]</p>"
        },
        {
          "type": "switch_gate",
          "stem": "\n                    otrzymujemy\n                    \n\n\n\n￿0￿.\n                ",
          "options": [
            "\\(a_1=3\\)",
            "\\(a_1=4\\)",
            "\\(a_1=5\\)"
