{
  "elements": [
    {
      "type": "text",
      "body": "<h3>\n    Równanie\n</h3>"
    },
    {
      "type": "text",
      "body": "<p>\n    Przypomnijmy:\n</p>"
    },
    {
      "type": "text",
      "body": "<p class=\"justified\">\n        Mówimy, że\n    </p>"
    },
    {
      "type": "text",
      "body": "<p class=\"centered\">\n        \"zmienna \\(y\\) jest\n        <strong>\n            odwrotnie proporcjonalna\n        </strong>\n        do zmiennej \\(x\\) ze stałą proporcjonalności \\(a\\) (\\(a\\ne 0\\))\"\n    </p>"
    },
    {
      "type": "text",
      "body": "<p class=\"justified\">\n        jeśli:\n    </p>"
    },
    {
      "type": "text",
      "body": "\\[xy=a\\]"
    },
    {
      "type": "text",
      "body": "<p>\n    Zauważ, że skoro \\(a\\ne 0\\), to także zarówno \\(x\\ne 0\\) jak i \\(y\\ne 0\\). Możemy więc podzielić równanie przez \\(x\\):\n</p>"
    },
    {
      "type": "text",
      "body": "\\[\ny=\\frac{a}{x}\n\\]"
    },
    {
      "type": "text",
      "body": "<p>\n    żeby otrzymać równanie funkcji proporcjonalności odwrotnej\n</p>"
    },
    {
      "type": "text",
      "body": "<h3>\n    Wykres\n</h3>"
    },
    {
      "type": "iframe",
      "url": "https://www.geogebra.org/material/iframe/id/tcq9akb4/width/1000/height/700/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/false/rc/false/ld/false/sdz/false/ctl/false",
      "title": ""
    },
    {
      "type": "text",
      "body": "<h3>\n    Własności\n</h3>"
    },
    {
      "type": "text",
      "body": "<p class=\"question\">\n</p>"
    },
    {
      "type": "text",
      "body": "\n<p>\n            Sprawdź, co pamiętasz.\n        </p>\n"
    },
    {
      "type": "spoiler",
      "label": "nazwa wykresu",
      "body": "\n<div>\n                            wykres funkcji proporcjonalności odwrotnej nazywamy <strong>hiperbolą</strong>\n</div>\n"
    },
    {
      "type": "spoiler",
      "label": "dziedzina",
      "body": "\n<div>\n                            \\(x\\in\\mathbb{R}\\setminus\\{0\\}\\) czyli \\(x\\in (-\\infty,0)\\cup(0,+\\infty)\\)\n                        </div>\n"
    },
    {
      "type": "spoiler",
      "label": "zbiór wartości",
      "body": "\n<div>\n                            \\(x\\in\\mathbb{R}\\setminus\\{0\\}\\) czyli \\(x\\in (-\\infty,0)\\cup(0,+\\infty)\\)\n                        </div>\n"
    },
    {
      "type": "spoiler",
      "label": "asymptoty",
      "body": "\n<p>\n                            asymptota <strong>pozioma</strong>: \\(y=0\\)\n                        </p>\n<p>\n                            asymptota <strong>pionowa</strong>: \\(x=0\\)\n                        </p>\n"
    },
    {
      "type": "spoiler",
      "label": "położenie wykresu",
      "body": "\n<div>\n                            Jeśli \\(a\\gt 0\\), gałęzie hiperboli znajdują się\n                            <span style=\"color: red\">\n                                w I (\\(\\nearrow\\)) i w III (\\(\\swarrow\\))\n                            </span>\n                            ćwiartce układu współrzędnych.\n                        </div>\n<div>\n                            Jeśli \\(a\\lt 0\\), gałęzie hiperboli znajdują się\n                            <span style=\"color: red\">\n                                w II (\\(\\nwarrow\\)) i w IV (\\(\\searrow\\))\n                            </span>\n                            ćwiartce układu współrzędnych.\n                        </div>\n"
    },
    {
      "type": "spoiler",
      "label": "monotoniczność",
      "body": "\n<p>\n                            Jeśli \\(a\\gt 0\\), funkcja\n                            <strong>\n<span style=\"color: red\">\n                                    maleje\n                                </span>\n</strong>\n                            w dwóch przedziałach: \\(x\\in (-\\infty,0)\\) oraz \\(x\\in(0,+\\infty)\\)\n                            <br/>\n                            \\(\\rightarrow\\)\n                            <u>\n                                uwaga\n                            </u>\n                            , funkcja\n                            <strong>\n                                nie maleje\n                            </strong>\n                            w zbiorze \\(\\mathbb{R}\\setminus\\{0\\}\\)\n                        </p>\n<p>\n                            Jeśli \\(a\\lt 0\\), funkcja\n                            <strong>\n<span style=\"color: red\">\n                                    rośnie\n                                </span>\n</strong>\n                            w dwóch przedziałach: \\(x\\in (-\\infty,0)\\) oraz \\(x\\in(0,+\\infty)\\)\n                            <br/>\n                            \\(\\rightarrow\\)\n                            <u>\n                                uwaga\n                            </u>\n                            , funkcja\n                            <strong>\n                                nie rośnie\n                            </strong>\n                            w zbiorze \\(\\mathbb{R}\\setminus\\{0\\}\\)\n                        </p>\n"
    }
  ],
