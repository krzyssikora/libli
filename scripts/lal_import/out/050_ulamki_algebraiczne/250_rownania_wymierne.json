        {
          "id": "t000001",
          "label": "opis",
          "elements": [
            {
              "type": "spoiler",
              "label": "krok 1. Analiza zadania.",
              "elements": [
                {
                  "type": "text",
                  "body": "<p>\n                    Czytajmy po kolei:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "<blockquote>\n                    Licznik ułamka jest o 80 większy od mianownika.\n                </blockquote>"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Przyjmijmy, że mianownik to \\(x\\) (przy czym oczywiście \\(x\\ne 0\\)). Wówczas ułamek ma postać\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\frac{x+80}{x}\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<blockquote>\n                    Gdyby licznik ułamka zmniejszyć dwukrotnie, a mianownik zwiększyć o 8...\n                </blockquote>"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    taki nowy ułamek miałby postać:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\frac{(x+80):2}{x+8}\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Uprośćmy to wyrażenie:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\frac{(x+80):2}{x+8}=\\frac{\\tfrac{1}{2}(x+80)}{x+8}\\cdot\\frac{2}{2}=\\frac{x+80}{2x+16}\n                \\]"
                }
              ]
            },
            {
              "type": "spoiler",
              "label": "krok 2. Równanie.",
              "elements": [
                {
                  "type": "table",
                  "data": {
                    "header_row": false,
                    "header_col": false,
                    "border": "grid",
                    "cells": [
                      [
                        {
                          "html": "pierwotny ułamek",
                          "halign": "left",
                          "valign": "top"
                        },
                        {
                          "html": "\\(\\frac{x+80}{x}\\)",
                          "halign": "left",
                          "valign": "top"
                        }
                      ],
                      [
                        {
                          "html": "ułamek po zmianie",
                          "halign": "left",
                          "valign": "top"
                        },
                        {
                          "html": "\\(\\frac{x+80}{2x+16}\\)",
                          "halign": "left",
                          "valign": "top"
                        }
                      ]
                    ]
                  }
                },
                {
                  "type": "text",
                  "body": "<p>\n                        no i teraz...\n                    </p>"
                },
                {
                  "type": "text",
                  "body": "<blockquote>\n                        tak otrzymany ułamek byłby od pierwotnego mniejszy o 4...\n                    </blockquote>"
                },
                {
                  "type": "text",
                  "body": "<p>\n                        czyli\n                    </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                    \\frac{x+80}{x} - 4 = \\frac{x+80}{2x+16}\n                    \\]"
                }
              ]
            },
            {
              "type": "spoiler",
              "label": "krok 3. Rowiązanie równania - przekształcenie równania wymiernego w kwadratowe.",
              "elements": [
                {
                  "type": "text",
                  "body": "\\[\n                \\frac{x+80}{x} - 4 = \\frac{x+80}{2x+16}\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Po lewej stronie równania mamy liczbę \\(4\\), czyli \\(\\frac{4x}{x}\\):\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\begin{align*}\n                \\frac{x+80}{x} - \\frac{4x}{x} &amp;= \\frac{x+80}{2x+16}\\\\\n                \\frac{x+80-4x}{x} &amp;= \\frac{x+80}{2x+16}\\\\\n                \\frac{80-3x}{x} &amp;= \\frac{x+80}{2x+16}\\\\\n                \\end{align*}\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Założenia są proste: \\(x\\ne 0\\) i \\(2x+16\\ne 0\\), czyli \\(x\\ne -8\\).\n                </p>"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    A metoda rozwiązania to mnożenie na skos:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                (80-3x)(2x+16)=x(x+80)\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Wymnóżmy wyrażenia, przenieśmy wszystkie wyrazy na jedną stronę i zredukujmy wyrazy podobne:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\begin{align*}\n                (80-3x)(2x+16) &amp;= x(x+80)\\\\\n                160x+1280-6x^2-48x &amp;= x^2+80x\\\\\n                -7x^2+32x+1280 &amp;=0\\\\\n                7x^2-32x-1280 &amp;=0\\\\\n                \\end{align*}\n                \\]"
                }
              ]
            },
            {
              "type": "spoiler",
              "label": "krok 4. Rowiązanie równania.",
              "elements": [
                {
                  "type": "text",
                  "body": "<p>\n                    Rozwiązujemy równanie z pomocą wzorów z deltą:\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\begin{align*}\n                \\Delta &amp;= (-32)^2-4\\cdot 7\\cdot (-1280)=36864=192^2\\\\\n                x &amp;= \\frac{-(-32)\\pm\\sqrt{192^2}}{2\\cdot 7}=\\\\\n                 &amp;= \\frac{32\\pm 192}{14}=\\\\\n                 &amp;= -\\frac{160}{14},\\quad\\quad \\frac{224}{14}=\\\\\n                 &amp;= -\\frac{80}{7},\\quad\\quad 16\\\\\n                \\end{align*}\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Pierwsze rozwiązanie nie ma sensu - po pierwsze jest ujemne, po drugie - niecałkowite. Oznacza to, że mianownik ułamka to \\(16\\).\n                </p>"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Początkowy ułamek to\n                </p>"
                },
                {
                  "type": "text",
                  "body": "\\[\n                \\frac{16+80}{16}=\\frac{96}{16}=6\n                \\]"
                },
                {
                  "type": "text",
                  "body": "<p>\n                    Wartość liczbowa początkowego ułamka to \\(6\\).\n                </p>"
                }
              ]
            }
          ]
        }
      ]
    }
