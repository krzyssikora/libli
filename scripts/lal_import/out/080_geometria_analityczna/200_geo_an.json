          "stem": "\n                    \\(x+2=-1\\) lub \\(x+2=1\\) oznacza, że \\(x=\\)\n                    \n\n\n￿0￿\n                    .\n                    \n",
          "options": [
            "\\(-3\\) lub \\(-1\\)",
