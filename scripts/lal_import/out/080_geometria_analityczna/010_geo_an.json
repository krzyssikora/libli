        {
          "type": "switch_gate",
          "stem": "\n                    Potrzebujemy długości przyprostokątnych, a do tego warto najpierw odczytać współrzędne punktów \\(A\\) i \\(B\\), czyli\n                    \n\n\n\n￿0￿\n                    .\n                    \n",
