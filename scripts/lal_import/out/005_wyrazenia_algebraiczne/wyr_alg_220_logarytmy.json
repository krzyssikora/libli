    {
      "type": "text",
      "body": "<p>\n<strong>\n            Logarytm o podstawie \\(a\\) z liczby \\(b\\)\n        </strong>\n        to odpowiedЕә na pytanie:\n    </p>"
    },
    {
      "type": "text",
      "body": "<blockquote class=\"centered\">\n        \"do jakiej potДҷgi podnieЕӣДҮ podstawДҷ \\(a\\), by uzyskaДҮ \\(b\\)\"\n    </blockquote>"
    },
    {
      "type": "text",
      "body": "\n        \\[\\log_a b=c\\quad\\quad\\Leftrightarrow\\quad\\quad a^c=b\\]\n    "
    },
    {
      "type": "text",
      "body": "<p>\n        przy czym \\(a\\gt 0\\), \\(a\\ne 1\\) i \\(b\\gt 0\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p>\n        W poniЕјszych zadaniach warto teЕј pamiДҷtaДҮ, Ејe\n        <span class=\"myequation\">\n            \\(a^1=a\\)\n        </span>\n        oraz\n        <span class=\"myequation\">\n            \\(a^0=1\\)\n        </span>\n        dla kaЕјdego \\(a\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Przyjrzyj siДҷ przykЕӮadowi i wpisz liczby w puste pola.\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n<span class=\"myequation\">\n                    \\(\\log_5 125 = 3\\)\n                </span>\n                , bo\n                <span class=\"myequation\">\n                    \\(5^3=125\\)\n                </span>\n</p>"
    },
    {
      "type": "fillblank",
      "stem": "\n<li>\n<span class=\"myequation\">\n                    \\(\\log_4 4 = \\)\n                    пҝҝ0пҝҝ\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(4\\)\n                    <sup>\nпҝҝ1пҝҝ\n</sup>\n                    \\(=4\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_7 1 = \\)\n                    пҝҝ2пҝҝ\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(7\\)\n                    <sup>\nпҝҝ3пҝҝ\n</sup>\n                    \\(=1\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_2 8 = \\)\n                    пҝҝ4пҝҝ\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(2\\)\n                    <sup>\nпҝҝ5пҝҝ\n</sup>\n                    \\(=8\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_3 9 = \\)\n                    пҝҝ6пҝҝ\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(3^2=\\)\n                    пҝҝ7пҝҝ\n</span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_9 3 = \\)\n                    пҝҝ8пҝҝ\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(9^{\\tfrac{1}{2}}=\\)\n                    пҝҝ9пҝҝ\n</span>\n</li>\n",
