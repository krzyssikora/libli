    {
      "type": "text",
      "body": "<p>\n<strong>\n            Logarytm o podstawie \\(a\\) z liczby \\(b\\)\n        </strong>\n        to odpowiedź na pytanie:\n    </p>"
    },
    {
      "type": "text",
      "body": "<blockquote class=\"centered\">\n        \"do jakiej potęgi podnieść podstawę \\(a\\), by uzyskać \\(b\\)\"\n    </blockquote>"
    },
    {
      "type": "text",
      "body": "\n        \\[\\log_a b=c\\quad\\quad\\Leftrightarrow\\quad\\quad a^c=b\\]\n    "
    },
    {
      "type": "text",
      "body": "<p>\n        przy czym \\(a\\gt 0\\), \\(a\\ne 1\\) i \\(b\\gt 0\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p>\n        W poniższych zadaniach warto też pamiętać, że\n        <span class=\"myequation\">\n            \\(a^1=a\\)\n        </span>\n        oraz\n        <span class=\"myequation\">\n            \\(a^0=1\\)\n        </span>\n        dla każdego \\(a\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Przyjrzyj się przykładowi i wpisz liczby w puste pola.\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n<span class=\"myequation\">\n                    \\(\\log_5 125 = 3\\)\n                </span>\n                , bo\n                <span class=\"myequation\">\n                    \\(5^3=125\\)\n                </span>\n</p>"
    },
    {
      "type": "html",
      "flagged": true,
      "raw": "<ol class=\"list15\">\n<li>\n<span class=\"myequation\">\n                    \\(\\log_4 4 = \\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(4\\)\n                    <sup>\n<input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</sup>\n                    \\(=4\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_7 1 = \\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(7\\)\n                    <sup>\n<input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</sup>\n                    \\(=1\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_2 8 = \\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(2\\)\n                    <sup>\n<input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</sup>\n                    \\(=8\\)\n                </span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_3 9 = \\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(3^2=\\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n</li>\n<li>\n<span class=\"myequation\">\n                    \\(\\log_9 3 = \\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n                , bo\n                <span class=\"myequation\">\n                    \\(9^{\\tfrac{1}{2}}=\\)\n                    <input class=\"table_input\" placeholder=\"wpisz\" type=\"text\"/>\n</span>\n</li>\n</ol>",
      "reason": "interactive_widget (Group B): table_input"
