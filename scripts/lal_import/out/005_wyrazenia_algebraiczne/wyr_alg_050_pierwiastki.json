{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n        Pierwiastek stopnia \\(n\\) z liczby \\(a\\) to taka liczba \\(b\\), której \\(n\\)-ta potęga jest równa \\(a\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p>\n        Zapisujemy to:\n    </p>"
    },
    {
      "type": "math",
      "latex": "\n    \\sqrt[n]{a}=b\\quad\\quad\\Leftrightarrow\\quad\\quad a=b^n\n    "
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>Uzupełnij puste pola liczbami.</p>"
    },
    {
      "type": "fillblank",
      "stem": "\n<li>\n                \\(3^5=243\\), więc\n                <span class=\"myequation\">\n                    \\(\\sqrt[5]{243}=\\)\n                    ￿0￿\n</span>\n</li>\n<li>\n                \\(5^4=625\\), więc\n                <span class=\"myequation\">\n                    \\(\\sqrt[4]{625}=\\)\n                    ￿1￿\n</span>\n</li>\n<li>\n                \\(2^7=128\\), więc\n                <span class=\"myequation\">\n                    \\(\\sqrt[7]{128}=\\)\n                    ￿2￿\n</span>\n</li>\n",
