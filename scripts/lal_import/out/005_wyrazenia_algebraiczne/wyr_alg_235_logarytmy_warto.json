        },
        {
          "type": "text",
          "body": "<p>\n            Jeśli podstawimy \\(x\\) oraz \\(y\\) z pierwszych dwóch równań do równania trzeciego, otrzymamy:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        a^n=a^k\\cdot a^m\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Kiedy mnożymy dwie potęgi o tej samej podstawie, dodajemy wykładniki, skąd:\n        </p>"
        },
        {
          "type": "math",
          "latex": "n=k+m"
        },
        {
          "type": "text",
