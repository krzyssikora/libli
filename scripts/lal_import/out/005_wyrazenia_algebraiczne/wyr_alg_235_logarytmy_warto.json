{
  "elements": [
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "\n        \\(\\log_a x+\\log_a y=\\log_a (x\\cdot y)\\)\n    "
    },
    {
      "type": "spoiler",
      "label": "dowód - zobacz",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Przyjmijmy oznaczenia:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(k=\\log_a x\\)\n            </li>\n<li>\n                \\(m=\\log_a y\\)\n            </li>\n<li>\n                \\(n=\\log_a \\left(\\frac{x}{y}\\right)\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Pokażemy, że \\(k-m=n\\)\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Zamieniając trzy powyższe równania logarytmiczne na potęgi otrzymamy:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(a^k=x\\)\n            </li>\n<li>\n                \\(a^m=y\\)\n            </li>\n<li>\n                \\(a^n=\\frac{x}{y}\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Jeśli podstawimy \\(x\\) oraz \\(y\\) z pierwszych dwóch równań do równania trzeciego, otrzymamy:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        a^n=\\frac{a^k}{a^m}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Kiedy dzielimy dwie potęgi o tej samej podstawie, odejmujemy wykładniki, skąd:\n        </p>"
        },
        {
          "type": "math",
          "latex": "n=k-m"
        },
        {
          "type": "text",
          "body": "<p>\n            co kończy dowód.\n        </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "\n        \\(\\log_a x-\\log_a y=\\log_a \\left(\\frac{x}{y}\\right)\\)\n    "
    },
    {
      "type": "spoiler",
      "label": "dowód - zobacz",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Oznaczmy:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(\\log_a \\left(n^s\\right)=p\\)\n            </li>\n<li>\n                \\(\\log_a n=q\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Pokażemy, że:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        p=s\\cdot q\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Zamieniając dwa powyższe równania logarytmiczne na potęgi otrzymamy:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(a^p=n^s\\)\n            </li>\n<li>\n                \\(a^q=n\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Wstawiając \\(n\\) z drugiego równania do pierwszego, otrzymujemy:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        a^p=\\left(a^q\\right)^s\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Kiedy podnosimy potęgę do potęgi, mnożymy wykładniki, więc:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        a^p=a^{q\\cdot s}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            skąd:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        p=q\\cdot s\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            co było do okazania.\n        </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "\n        \\(\\log_a \\left(n^s\\right)=s\\cdot\\log_a n\\)\n    "
    },
    {
      "type": "spoiler",
      "label": "dowód - zobacz",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Przyjmijmy oznaczenia:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(k=\\log_a b\\)\n            </li>\n<li>\n                \\(m=\\log_c b\\)\n            </li>\n<li>\n                \\(n=\\log_c a\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Pokażemy, że \\(k=\\frac{m}{n}\\)\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Zamieniając trzy powyższe równania logarytmiczne na potęgi otrzymamy:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(a^k=b\\)\n            </li>\n<li>\n                \\(c^m=b\\)\n            </li>\n<li>\n                \\(c^n=a\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Zestawmy najpierw razem pierwsze dwa równania:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        a^k=c^m\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            i teraz podstawmy do tak otrzymanego równania \\(a=c^n\\):\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\left(c^n\\right)^k=c^m\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Kiedy podnosimy potęgę do potęgi, mnożymy wykładniki, więc:\n        </p>"
        },
        {
          "type": "math",
          "latex": "c^{n\\cdot k}=c^m"
        },
        {
          "type": "text",
          "body": "<p>\n            czyli:\n        </p>"
        },
        {
          "type": "math",
          "latex": "n\\cdot k=m"
        },
        {
          "type": "text",
          "body": "<p>\n            a to oznacza, że:\n        </p>"
        },
        {
          "type": "math",
          "latex": "k=\\frac{m}{n}"
        },
        {
          "type": "text",
          "body": "<p>\n            co kończy dowód.\n        </p>"
        }
      ]
    },
    {
      "type": "text",
      "body": "\n        \\(\\log_a b=\\frac{\\log_c b}{\\log_c a}\\)\n    "
    },
    {
      "type": "spoiler",
      "label": "dowód - zobacz",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Przyjmijmy oznaczenia:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul class=\"nolist\">\n<li>\n                \\(k=\\log_a x\\)\n            </li>\n<li>\n                \\(m=\\log_a y\\)\n            </li>\n<li>\n                \\(n=\\log_a (x\\cdot y)\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Pokażemy, że \\(k+m=n\\)\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Zamieniając trzy powyższe równania logarytmiczne na potęgi otrzymamy:\n        </p>"
        },
        {
