    },
    {
      "type": "fill_gate",
      "stem": "\n<p>\n                Włącz liczbę \\(3\\) sprzed pierwiastka w liczbie \\(3\\sqrt{5}\\) pod pierwiastek, to znaczy znajdź taką liczbę \\(a\\), że\n            </p>\n            \\[\n            3\\sqrt{5}=\\sqrt{a}\n            \\]\n            <p>\n                Wówczas\n            </p>\n<span class=\"myequation\">\n                \\(a=\\)\n                <span>\n￿0￿\n</span>\n</span>\n",
