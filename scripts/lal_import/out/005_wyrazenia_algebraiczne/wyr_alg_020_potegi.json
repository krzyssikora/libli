    {
      "type": "math",
      "latex": "\n                                                                                        \\begin{align*}\n                                                                                        a^n\\cdot a^k&=a^{n+k}\\\\\n                                                                                        a^n: a^k&=a^{n-k}\\\\\n                                                                                        \\left(a^n\\right)^k&=a^{nk}\n                                                                                        \\end{align*}\n                                                                                        "
    },
    {
      "type": "text",
      "body": "<p>\n        Pamiętaj także, że:\n    </p>"
