      "latex": "\n                                                                                        \\begin{align*}\n                                                                                        (ab)^n&=a^n\\cdot b^n\\\\\n                                                                                        \\left(\\frac{a}{b}\\right)^n&=\\frac{a^n}{b^n}\n                                                                                        \\end{align*}\n                                                                                        "
