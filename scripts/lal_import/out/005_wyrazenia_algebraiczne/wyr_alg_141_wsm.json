        {
          "id": "t000000",
          "label": "kwadrat sumy",
          "elements": [
            {
              "type": "video",
              "media_src": "static/wsm_kwadrat_sumy.mp4"
            },
            {
              "type": "text",
              "body": "\n            \\[\n            (a+b)^2 = a^2+2ab+b^2\n            \\]\n        "
            },
            {
              "type": "text",
              "body": "<strong style=\"color: red\">\n            Uwaga!\n        </strong>"
            },
            {
              "type": "text",
              "body": "<p>\n            W miejsce zmiennych \\(a\\) i \\(b\\) możemy wstawić dowolne inne liczby lub wyrażenia:\n        </p>"
            },
            {
              "type": "math",
              "latex": "\n        \\begin{align*}\n        (\\color{red}{a}+\\color{blue}{b})^2 &= \\color{red}{a}^2+2\\color{red}{a}\\color{blue}{b}+\\color{blue}{b}^2\\\\[10pt]\n        (\\color{red}{2xy}+\\color{blue}{3y^2})^2 &= (\\color{red}{2xy})^2+2\\cdot\\color{red}{2xy}\\cdot\\color{blue}{3y^2}+(\\color{blue}{3y^2})^2\\\\\n        &= 4x^2y^2+12xy^3+9y^4\n        \\end{align*}\n        "
            }
          ]
        },
        {
          "id": "t000001",
          "label": "kwadrat różnicy",
          "elements": [
            {
              "type": "video",
              "media_src": "static/wsm_kwadrat_roznicy.mp4"
            },
            {
              "type": "text",
              "body": "\n            \\[\n            (a-b)^2 = a^2-2ab+b^2\n            \\]\n        "
            },
            {
              "type": "text",
              "body": "<strong style=\"color: red\">\n            Uwaga!\n        </strong>"
            },
            {
              "type": "text",
              "body": "<p>\n            Jak poprzednio, w miejsce zmiennych \\(a\\) i \\(b\\) możemy wstawić dowolne inne liczby lub wyrażenia:\n        </p>"
            },
            {
              "type": "math",
              "latex": "\n        \\begin{align*}\n        (\\color{red}{a}-\\color{blue}{b})^2 &= \\color{red}{a}^2+2\\color{red}{a}\\color{blue}{b}+\\color{blue}{b}^2\\\\[10pt]\n        (\\color{red}{2xy}-\\color{blue}{3y^2})^2 &= (\\color{red}{2xy})^2-2\\cdot\\color{red}{2xy}\\cdot\\color{blue}{3y^2}+(\\color{blue}{3y^2})^2\\\\\n        &= 4x^2y^2-12xy^3+9y^4\n        \\end{align*}\n        "
            }
          ]
        },
        {
          "id": "t000002",
          "label": "różnica kwadratów",
          "elements": [
            {
              "type": "video",
              "media_src": "static/wsm_roznica_kwadratow.mp4"
            },
            {
              "type": "text",
              "body": "\n            \\[\n            (a+b)(a-b) = a^2-b^2\n            \\]\n        "
            },
            {
              "type": "text",
              "body": "<strong style=\"color: red\">\n            Uwaga!\n        </strong>"
            },
            {
              "type": "text",
              "body": "<p>\n            Ponownie, w miejsce zmiennych \\(a\\) i \\(b\\) możemy wstawić dowolne inne liczby lub wyrażenia:\n        </p>"
            },
            {
              "type": "math",
              "latex": "\n        \\begin{align*}\n        (\\color{red}{a}+\\color{blue}{b})(\\color{red}{a}-\\color{blue}{b}) &= \\color{red}{a}^2-\\color{blue}{b}^2\\\\[10pt]\n        (\\color{red}{2xy}+\\color{blue}{3y^2})(\\color{red}{2xy}-\\color{blue}{3y^2}) &= (\\color{red}{2xy})^2-(\\color{blue}{3y^2})^2\\\\\n        &= 4x^2y^2-9y^4\n        \\end{align*}\n        "
            }
          ]
        }
      ]
    }
