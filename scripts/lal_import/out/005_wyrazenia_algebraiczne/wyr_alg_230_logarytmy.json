    },
    {
      "type": "text",
      "body": "\n        Przypomnij sobie wzory na działania na potęgach i sprawdź, czy dobrze pamiętasz.\n    "
    },
    {
      "type": "spoiler",
      "label": "\\(a^n\\cdot a^k=a^{n+k}\\)",
      "body": "\n                    \\(a^n\\cdot a^k=a^{n+k}\\)\n                "
    },
    {
      "type": "spoiler",
      "label": "\\(a^n: a^k=a^{n-k}\\)",
      "body": "\n                    \\(a^n: a^k=a^{n-k}\\)\n                "
    },
    {
      "type": "spoiler",
      "label": "\\(\\left(a^n\\right)^k=a^{nk}\\)",
