>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n</table>\n</div>\n</div>\n<div class=\"show_next ks_button\">\n                pokaĹĽ dalej\n            </div>\n<div class=\"show_step\">\n<p>\n                    To, co zrobiliĹ›my do tej pory, to pierwszy cykl:\n                    <strong>\n                        dzielimy-mnoĹĽymy-odejmujemy\n                    </strong>\n                    .\n                </p>\n<p>\n                    Zaczynamy drugi cykl, czyli znĂłw\n                    <strong>\n                        dzielimy\n                    </strong>\n                    : \\(-6x^2\\) przez \\(2x\\).\n                </p>\n                \\[\n                \\frac{-6x^2}{2x}=-3x\n                \\]\n                <div class=\"table_wrapper\">\n<table class=\"my_table_noborder table_centered\" data-cellwidth=\"40px\">\n<tr style=\"border-bottom: 1px solid black;\">\n<td>\n                                \\(x^2\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\(-3x\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n<tr>\n<td>\n                                \\((2x^3\\)\n                            </td>\n<td>\n                                \\(-9x^2\\)\n                            </td>\n<td>\n                                \\(+13x\\)\n                            </td>\n<td>\n                                \\(+1)\\)\n                            </td>\n<td>\n                                \\(:\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\((2x\\)\n                            </td>\n<td>\n                                \\(-3)\\)\n                            </td>\n</tr>\n<tr style=\"border-bottom: 1px solid black;\">\n<td>\n                                \\(2x^3\\)\n                            </td>\n<td>\n                                \\(-3x^2\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n<tr>\n<td>\n                                \\(=\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\(-6x^2\\)\n                            </td>\n<td>\n                                \\(+13x\\)\n                            </td>\n<td>\n                                \\(+1\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n</table>\n</div>\n</div>\n<div class=\"show_next ks_button\">\n                pokaĹĽ dalej\n            </div>\n<div class=\"show_step\">\n<p>\n                    ZnĂłw\n                    <strong>\n                        mnoĹĽymy\n                    </strong>\n                    , przez\n                    <u>\n                        caĹ‚y\n                    </u>\n                    dzielnik: \n                    \\[\n                    -3x\\cdot (2x-3)=-6x^2+9x\n                    \\]\n                </p>\n<div class=\"table_wrapper\">\n<table class=\"my_table_noborder table_centered\" data-cellwidth=\"40px\">\n<tr style=\"border-bottom: 1px solid black;\">\n<td>\n                                \\(x^2\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\(-3x\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n<tr>\n<td>\n                                \\((2x^3\\)\n                            </td>\n<td>\n                                \\(-9x^2\\)\n                            </td>\n<td>\n                                \\(+13x\\)\n                            </td>\n<td>\n                                \\(+1)\\)\n                            </td>\n<td>\n                                \\(:\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\((2x\\)\n                            </td>\n<td class=\"red_on_yellow\">\n                                \\(-3)\\)\n                            </td>\n</tr>\n<tr style=\"border-bottom: 1px solid black;\">\n<td>\n                                \\(2x^3\\)\n                            </td>\n<td>\n                                \\(-3x^2\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n<td>\n                                \\(\\)\n                            </td>\n</tr>\n<tr