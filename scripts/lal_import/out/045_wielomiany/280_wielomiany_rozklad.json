          ]
        },
        {
          "id": "t000001",
          "label": "schemat Hornera",
          "elements": [
            {
              "type": "text",
              "body": "<p>\n                            A tu musimy chwilę pomyśleć. Schemat Hornera pozwala tylko na dzielenie przez dwumiany postaci \\((x-\\alpha)\\).\n                        </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                            My chcemy podzielić przez \\((2x-1)\\). Podzielmy więc najpierw przez \\(\\left(x-\\tfrac{1}{2}\\right)\\), a potem przez \\(2\\).\n                        </p>"
            },
            {
