                  ]
                ]
              }
            },
            {
              "type": "text",
              "body": "<p>\n                            Z dzielenia przez \\(\\left(x-\\tfrac{1}{2}\\right)\\) wyszło\n                            <br/>\n<span style=\"display: inline-block; width: 50px;\">\n</span>\n                            \\(12x^2+2x-2\\)\n                        </p>"
            },
            {
              "type": "text",
              "body": "<p>\n                            Z dzielenia przez \\(\\left(2x-1\\right)\\) wyjdzie \\(2\\) razy mniej, czyli\n                            <br/>\n<span style=\"display: inline-block; width: 50px;\">\n</span>\n                            \\(6x^2+x-1\\)\n                            <br/>\n                            czyli\n                        </p>"
            },
            {
              "type": "math",
              "latex": "\n                        W(x)=(2x-1)(6x^2+x-1)\n                        "
            }
          ]
        }
      ]
    },
    {
      "type": "switch_gate",
      "stem": "\n\n\n                    Wynikiem dzielenia przez \\((2x-1)\\) jest\n                    \n\n\n￿0￿\n                    .\n                    \n",
      "options": [
        "\\((12x^2+2x-2)\\)",
        "\\((6x^2+x-1)\\)",
        "\\((x^2+x-6)\\)"
      ],
      "answer": 1
    },
    {
      "type": "text",
      "body": "<p>\n                    Wiemy już, że\n                </p>"
    },
    {
      "type": "text",
      "body": "<p>\\[\n                \\begin{align*}\n                W(x)&=12x^3-4x^2-3x+1=\\\\\n                    &=(2x-1)(6x^2+x-1)\n                \\end{align*}\n                \\]\n                czyli znamy:</p>"
    },
    {
      "type": "text",
      "body": "<ul class=\"nolist\">\n<li>\n                        jeden pierwiastek wielomianu: \\(x=\\tfrac{1}{2}\\)\n                    </li>\n<li>\n                        oraz jeden czynnik w rozkładzie wielomianu: \\((2x-1)\\).\n                    </li>\n</ul>"
    },
    {
      "type": "text",
      "body": "<p>\n                    Musimy znaleźć pierwiastki z czynnika \\((6x^2+x-1)\\) i rozłożyć go na \"drobniejsze\" czynniki.\n                </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                    I\n                    <strong>\n                        mamy dwie możliwości\n                    </strong>\n                    :\n                </p>"
    },
    {
      "type": "text",
