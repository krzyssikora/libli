    },
    {
      "type": "text",
      "body": "<p>\n                        Od tego momentu robimy w kółko to samo, aż wypełnimy tabelę:\n                    </p>"
    },
    {
      "type": "text",
      "body": "<ol class=\"bold\">\n<li>\n<span class=\"blue_on_green\" style=\"display: inline-block; height: 2em;\">\n                                mnożymy ostatni wynik przez liczbę z lewej \\(\\left(\\frac{3}{2}\\right)\\)\n                            </span>\n                            ,\n                        </li>\n<li>\n<span class=\"red_on_yellow\">\n                                dodajemy kolejną liczbę z góry\n                            </span>\n                            i wpisujemy w kolejną komórkę.\n                        </li>\n</ol>"
    },
