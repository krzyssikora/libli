      "body": "\n<span class=\"blue_on_green\" style=\"display: inline-block; height: 2em;\">\n                            \\(\\frac{3}{2}\\)\n                        </span>\n                        \\(\\cdot 2+\\)\n                        <span class=\"red_on_yellow\" style=\"display: inline-block; height: 1.5em;\">\n                            \\((-9)\\)\n                        </span>\n                        \\(=\\)\n                        <span class=\"magenta_on_gray\">\n                            \\(-6\\)\n                        </span>\n"
