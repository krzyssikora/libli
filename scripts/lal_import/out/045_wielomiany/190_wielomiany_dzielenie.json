        },
        {
          "type": "switch_gate",
          "stem": "\n\n                        5.\n                    \n                    W działaniu \\((-6x^2+\\color{red}{13x}):(2x-3)\\) czerwony wyraz powinien być równy\n                    \n\n\n￿0￿\n                    .\n                    \n",
