        {
          "type": "math",
          "latex": "\n                2x^3-9x^2+13x+1=\\underbrace{(x^2-3x+2)(2x-3)}_{\\text{część podzielna przez }(2x-3)}+\\underbrace{7}_{\\text{reszta}}\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    tak więc wynikiem dzielenia jest \\((x^2-3x+2)\\), a reszta to \\(7\\).\n                </p>"
        }
      ]
    },
    {
