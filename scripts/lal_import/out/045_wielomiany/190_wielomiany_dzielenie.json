        {
          "type": "math",
          "latex": "\n                \\begin{align*}\n                2x^3&\\underline{-9x^2}=\\\\\n                =2x^3&\\underline{-3x^2-6x^2}\n                \\end{align*}\n                "
        },
        {
          "type": "text",
          "body": "<p>\n                    czyli cały wielomian:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                \\color{red}{2x^3-3x^2-6x^2}+13x+1\n                "
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Wyłączmy maksymalny wspólny czynnik z dwóch pierwszych wyrazów i skupmy się na\n                    <span style=\"color: red;\">\n                        dwóch kolejnych\n                    </span>\n                    .\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                x^2(2x-3)\\color{red}{-6x^2+13x}+1\n                "
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Żeby móc je podzielić przez \\((2x-3)\\), zamiast\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\(\\color{red}{-6x^2+13x}\\) powinniśmy mieć \\(\\color{red}{-6x^2+9x}\\)\n                "
