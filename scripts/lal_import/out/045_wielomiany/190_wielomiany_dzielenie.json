        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Dlatego zapiszemy:\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                \\begin{align*}\n                -6x^2&\\underline{+13x}=\\\\\n                =-6x^2&\\underline{+9x+4x}\n                \\end{align*}\n                "
