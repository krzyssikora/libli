        },
        {
          "type": "text",
          "body": "<p>\n                    Ponownie wyłączmy maksymalny wspólny czynnik z dwóch zmienionych wyrazów a na końcu zostanie tylko \\(\\color{red}{7}\\).\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                x^2(2x-3)-3x(2x-3)+2(2x-3)+\\color{red}{7}\n                "
