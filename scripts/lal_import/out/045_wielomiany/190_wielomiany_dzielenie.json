        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    W tej końcowej siódemce nie ma już \\(x\\)-a, zostawmy ją więc w spokoju, a przyjrzyjmy się temu, co jest przed nią:\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\(x^2\\)\n                    <span class=\"magenta_on_gray\">\n                        \\((2x-3)\\)\n                    </span>\n                    \\(-3x\\)\n                    <span class=\"magenta_on_gray\">\n                        \\((2x-3)\\)\n                    </span>\n                    \\(+2\\)\n                    <span class=\"magenta_on_gray\">\n                        \\((2x-3)\\)\n                    </span>\n                    \\(+7\\)\n                "
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Widzimy tam wspólny czynnik\n                    <span class=\"magenta_on_gray\">\n                        \\((2x-3)\\)\n                    </span>\n                    , który wyłączymy poza nawias:\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\((x^2-3x+2)\\)\n                    <span class=\"magenta_on_gray\">\n                        \\((2x-3)\\)\n                    </span>\n                    \\(+7\\)\n                "
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    I tak oto przedstawiliśmy dany wielomian w postaci sumy wdóch części:\n                </p>"
