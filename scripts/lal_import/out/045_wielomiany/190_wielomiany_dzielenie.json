        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Żeby móc je podzielić przez \\((2x-3)\\), zamiast\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\(\\color{red}{4x+1}\\) powinniśmy mieć \\(\\color{red}{4x-6}\\)\n                "
