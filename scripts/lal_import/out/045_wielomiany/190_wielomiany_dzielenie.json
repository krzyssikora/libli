        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Wyłączmy maksymalny wspólny czynnik z dwóch zmienionych wyrazów i skupmy się na\n                    <span style=\"color: red;\">\n                        dwóch kolejnych\n                    </span>\n                    .\n                </p>"
        },
        {
          "type": "math",
          "latex": "\n                x^2(2x-3)-3x(2x-3)+\\color{red}{4x+1}\n                "
