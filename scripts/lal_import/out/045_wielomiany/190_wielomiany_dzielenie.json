    {
      "type": "text",
      "body": "<p><strong>Przykład</strong></p>"
    },
    {
      "type": "text",
      "body": "\n        Ponownie podzielimy wielomian \\(2x^3-9x^2+13x+1\\) przez \\(2x-3\\).\n    "
    },
    {
      "type": "spoiler",
      "label": "rozwiązanie",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Skupmy się na dwóch pierwszych wyrazach dzielonego wielomianu:\n            \\[\n            \\color{red}{2x^3-9x^2}+13x+1\n            \\]\n        </p>"
        },
        {
          "type": "reveal_gate",
          "label": "pokaż dalej"
        },
        {
          "type": "text",
          "body": "<p>\n                    Żeby móc je podzielić przez \\((2x-3)\\), zamiast\n                </p>"
        },
        {
          "type": "text",
          "body": "\n                    \\(\\color{red}{2x^3-9x^2}\\) powinniśmy mieć \\(\\color{red}{2x^3-3x^2}\\)\n                "
