{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n<a href=\"https://pl.wikipedia.org/wiki/%C3%89tienne_B%C3%A9zout\">\n        Étienne Bézout\n    </a>\n    był francuskim matematykiem żyjącym w XVIII wieku.\n</p>"
    },
    {
      "type": "text",
      "body": "<p>\n    W Polsce jego nazwiskiem nazwano następujące twierdzenie.\n</p>"
    },
    {
      "type": "text",
      "body": "<p>\n<strong>\n            Twierdzenie Bézout\n        </strong>\n</p>"
    },
    {
      "type": "text",
      "body": "<p>\n        Liczba \\(a\\) jest pierwiastkiem wielomianu \\(W(x)\\) (tzn. \\(W(a)=0\\))\n    </p>"
    },
    {
      "type": "text",
      "body": "<p>\n<em>\n            wtedy i tylko wtedy gdy\n        </em>\n</p>"
    },
    {
      "type": "text",
      "body": "<p>\n        wielomian \\(W(x)\\) jest podzielny przez \\((x-a)\\).\n    </p>"
    },
    {
      "type": "text",
      "body": "<p><strong>Przykład</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n        Rozpatrzmy wielomian\n    </p>"
    },
    {
      "type": "math",
      "latex": "\n    W(x)=x^5-2x^4-13x^3+28x^2+46x-60\n    "
    },
    {
      "type": "text",
      "body": "<p>\n        Zauważmy, że\n    </p>"
    },
    {
      "type": "spoiler",
      "label": "Po pierwsze, \\(W(1)\\)",
      "elements": [
        {
          "type": "math",
          "latex": "\n        \\begin{align*}\n        W(1)&=1^5-2\\cdot 1^4-13\\cdot 1^3+28\\cdot 1^2+46\\cdot 1-60=\\\\\n            &=1-2-13+28+46-60=\\\\\n            &=0\n        \\end{align*}\n        "
        }
      ]
    },
    {
      "type": "spoiler",
      "label": "Po drugie, \\(W(x):(x-1)\\)",
      "elements": [
