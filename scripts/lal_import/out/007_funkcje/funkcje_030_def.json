{
  "elements": [
    {
      "type": "text",
      "body": "<p>\n    Wykres funkcji to najczęściej więcej niż kilka punktów.\n</p>"
    },
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Naszkicujemy wykres funkcji\n        </p>"
    },
    {
      "type": "math",
      "latex": "\n        f:\\langle 2, 6)\\longrightarrow \\mathbb{R}\n        "
    },
    {
      "type": "text",
      "body": "<p>\n            zdefiniowanej\n        </p>"
    },
    {
      "type": "math",
      "latex": "\n        f(x)=\\frac{1}{2}x-2\n        "
    },
    {
      "type": "text",
      "body": "<p>\n                Dziedzina \\(\\langle 2, 6)\\) jest zbiorem o nieskończonej liczbie elementów. Nie policzymy wartości dla wszystkich, ale możemy policzyć dla kilku i zaobserwować, jak wykres powinien wyglądać.\n            </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                Rozpatrzmy wartości \\(y\\) dla\n                <strong>\n                    całkowitych\n                </strong>\n                argumentów \\(x\\).\n            </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                Dla \\(x=2\\), \\(f(2)=\\frac{1}{2}\\cdot 2-2=-1\\).\n            </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                Dla \\(x=3\\), \\(f(3)=\\frac{1}{2}\\cdot 3-2=-\\frac{1}{2}\\).\n            </p>"
    },
    {
      "type": "switch_gate",
      "stem": "\n                Dla \\(x=4\\), \\(f(4)=\\frac{1}{2}\\cdot 4-2=\\)\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(-1\\)",
        "\\(0\\)",
        "\\(1\\)",
        "\\(2\\)"
      ],
      "answer": 1
    },
    {
      "type": "text",
      "body": "<p>\n                Dla \\(x=5\\), \\(f(2)=\\frac{1}{2}\\cdot 5-2=\\frac{1}{2}\\).\n            </p>"
    },
    {
      "type": "text",
      "body": "<p>\n                Kolejna liczba całkowita, \\(x=6\\), już nie należy do dziedziny, jednak policzmy wartość tak, jakby dziedzina była o ten jeden punkt większa.\n            </p>"
    },
    {
      "type": "switch_gate",
      "stem": "\n                Dla \\(x=6\\), \\(f(6)=\\frac{1}{2}\\cdot 6-2=\\)\n                \n\n\n\n￿0￿\n                .\n                \n",
      "options": [
        "\\(-1\\)",
        "\\(0\\)",
        "\\(1\\)",
        "\\(2\\)"
      ],
      "answer": 2
    },
    {
      "type": "text",
      "body": "<p>\n                Otrzymaliśmy następujące wartości:\n            </p>"
    },
