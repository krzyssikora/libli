    },
    {
      "type": "switch_gate",
      "stem": "\n                        Upraszczając wyrażenie po lewej stronie równania, a następnie dzieląc jego obie strony przez \\(2\\) otrzymujemy\n                        \n\n\n\n\n￿0￿",
