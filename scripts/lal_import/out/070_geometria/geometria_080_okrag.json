    },
    {
      "type": "text",
      "body": "<p><strong>\n        Okrąg\n    </strong>\n    o środku w punkcie \\(O\\) i promieniu \\(r\\) (gdzie \\(r\\gt 0\\)) to zbiór wszystkich punktów płaszczyzny, których odległość od punktu \\(O\\) jest\n    <u>\n        równa\n    </u>\n    \\(r\\).</p>"
    },
