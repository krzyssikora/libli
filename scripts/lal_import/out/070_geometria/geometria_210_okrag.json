      "figcaption": ""
    },
    {
      "type": "switch_gate",
      "stem": "\n                        Z twierdzenia o potędze punktu \\(P\\) względem okręgu \\(o\\)\n                        \n\n\n\n￿0￿\n                        .\n                        \n",
      "options": [
        "\\((4-r)(4+r)=3\\cdot 1\\)",
        "\\(3(4-r)=4(4+r)\\)",
        "\\((4-r)(4+r)=3\\cdot 4\\)",
        "\\(4(4-r)=3(4+r)\\)"
      ],
      "answer": 2
    },
    {
      "type": "text",
      "body": "<p>\n                        Rozwiązując równanie\n                    </p>"
    },
    {
      "type": "math",
      "latex": "\n                                                                                                        \\begin{align*}\n                                                                                                        (4-r)(4+r)&=3\\cdot 4\\\\\n                                                                                                        16-r^2&=12\\\\\n                                                                                                        r^2&=4\n                                                                                                        \\end{align*}\n                                                                                                        "
    },
    {
      "type": "switch_gate",
      "stem": "\n                        Rozwiązaniami równania \\(r^2=4\\) są\n                        \n\n\n￿0￿\n                        .\n                        \n",
