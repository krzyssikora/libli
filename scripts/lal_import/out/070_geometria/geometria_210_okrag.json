    },
    {
      "type": "switch_gate",
      "stem": "\n                        Jeśli oznaczymy promień okręgu przez \\(r\\), to odległość od punktu \\(P\\) do punktu przecięcia okręgu i odcinka \\(PS\\) jest równa\n                        \n\n\n￿0￿\n                        .\n                        \n",
      "options": [
        "\\(4\\)",
        "\\(4-r\\)",
        "\\(4+r\\)"
      ],
      "answer": 1
    },
    {
      "type": "switch_gate",
      "stem": "\n                        Jeśli przedłużymy odcinek \\(PS\\) poza punkt \\(S\\) aż do przecięcia z okręgiem, to odległość od tego przecięcia do punktu \\(P\\) jest równa\n                        \n\n\n￿0￿\n                        .\n                        \n",
      "options": [
        "\\(4+r\\)",
        "\\(4\\)",
        "\\(4-r\\)"
      ],
      "answer": 0
    },
    {
      "type": "image",
