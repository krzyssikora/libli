          "figcaption": ""
        }
      ]
    },
    {
      "type": "spoiler",
      "label": "kąty odpowiadające",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n                                    Katy\n                                    <strong>\n                                        odpowiadające\n                                    </strong>\n                                    powstają z przecięcia dwóch prostych trzecią, po tej samej stronie tej trzeciej.\n                                </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                                    Gdy dwie pierwsze proste są\n                                    <strong>\n                                        równoległe\n                                    </strong>\n                                    , kąty odpowiadające mają\n                                    <strong>\n                                        tę samą miarę\n                                    </strong>\n                                    .\n                                </p>"
        },
        {
          "type": "text",
          "body": "<p>\n                                    Na rysunku poniżej zarówno kąty oznaczone na czerwono jak i te oznaczone na niebiesko są odpowiadające.\n                                </p>"
