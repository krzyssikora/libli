{
  "elements": [
    {
      "type": "text",
      "body": "<p><strong>Zadanie</strong></p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Na rysunku poniżej odcinki \\(DE\\) oraz \\(BC\\) są równoległe.\n        </p>"
    },
    {
      "type": "image",
      "media_src": "static/twierdzenie_Talesa_zadanie_3.png",
      "alt": "twierdzenie Talesa, zadanie",
      "figcaption": ""
    },
    {
      "type": "text",
      "body": "<p>\n            Znając długości odcinków: \\(AD=25\\), \\(AB=10\\) i \\(CE=56\\), znajdź długość odcinka \\(AC\\).\n        </p>"
    },
    {
      "type": "text",
      "body": "<p>\n            Spróbuj rozwiązać zadanie samodzielnie, a następnie obejrzyj moje rozwiązanie.\n        </p>"
    },
    {
      "type": "spoiler",
      "label": "Rozwiązanie zadania - zobacz",
      "elements": [
        {
          "type": "text",
          "body": "<p>\n            Z twierdzenia Talesa wynika, że czerwony odcinek \\(CE\\) jest w takim stosunku do \\(BD\\) jak dowolny innny czerwony odcinek do odpowiadającego mu czarnego.\n        </p>"
        },
        {
          "type": "text",
          "body": "<p>\n            Na przykład:\n        </p>"
        },
        {
          "type": "text",
          "body": "<ul>\n<li>\n                \\(AC\\) do \\(AB\\), i wówczas otrzymujemy proporcję: \\(\\frac{CE}{BD}=\\frac{AC}{AB}\\)\n            </li>\n<li>\n                \\(AE\\) do \\(AD\\), i wówczas otrzymujemy proporcję: \\(\\frac{CE}{BD}=\\frac{AE}{AD}\\)\n            </li>\n</ul>"
        },
        {
          "type": "text",
          "body": "<p>\n            Chcemy znaleźć długość \\(AC\\), więc potrzebna nam jest ta pierwsza proporcja:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\frac{CE}{BD}=\\frac{AC}{AB}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Podstawmy dane długości:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\frac{56}{10+25}=\\frac{AC}{10}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            czyli:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\frac{56}{35}=\\frac{AC}{10}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            Skróćmy ułamek po lewej stronie przez 7:\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\frac{8}{5}=\\frac{AC}{10}\n        "
        },
        {
          "type": "text",
          "body": "<p>\n            I wyliczmy \\(AC\\):\n        </p>"
        },
        {
          "type": "math",
          "latex": "\n        \\begin{align*}\n        5\\cdot AC&=8\\cdot 10\\\\\n        AC&=8\\cdot 2\\\\\n        AC&=16\\\\\n        \\end{align*}\n        "
        }
      ]
    }
  ],
  "fully_mapped": true,
